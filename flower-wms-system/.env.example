# PostgreSQL 连接串（Prisma 7 通过 adapter-pg 使用）
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/flower_wms?schema=public"

# Auth.js (NextAuth v5) — 后台员工登录
AUTH_SECRET="请更换为足够长的随机字符串"
NEXTAUTH_SECRET="请更换为足够长的随机字符串"
NEXTAUTH_URL="http://localhost:3000"

# 小程序 / 外网访问 Next 静态资源与 API 的基址（真机联调请改为局域网 IP）
NEXT_PUBLIC_ASSET_BASE_URL="http://192.168.31.200:3000"
NEXT_PUBLIC_API_URL="http://192.168.31.200:3000"

# 微信小程序
WECHAT_MINI_APP_ID=""
WECHAT_MINI_APP_SECRET=""
WECHAT_JWT_SECRET="请更换为足够长的随机字符串"

# DeepSeek AI — 物料智库智能补全（拉丁名 / 养护表格）
DEEPSEEK_API_KEY=""
# 可选，默认 deepseek-chat；若 DeepSeek 提供 v4 pro 模型名请在此覆盖
DEEPSEEK_MODEL="deepseek-chat"

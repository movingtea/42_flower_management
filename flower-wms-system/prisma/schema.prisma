// =============================================================================
// Flower WMS — 花店仓库管理与微信小程序订单
// 架构：Product（前台成品）↔ ProductBOM ↔ Material（仓储原材料）+ Batch FIFO
// 商品分类与原材料分类完全解耦，各自独立表与中间表
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// 库存流水类型
enum StockLogType {
  INBOUND /// 采购入库（增加批次可用量）
  SALE_OUT /// 销售出库（FIFO 扣减）
  WASTAGE_OUT /// 损耗出库（FIFO 扣减）
  ADJUSTMENT /// 盘点调整（可正可负）
  IN_CANCEL /// 订单取消释放库存（对冲下单锁库）
}

/// 微信订单状态
enum OrderStatus {
  PENDING /// 待付款（已锁库计划，未正式扣减）
  PAID /// 已付款
  PREPARING /// 制作中
  DELIVERED /// 已送达
  CANCELLED /// 已取消
}

// ---------------------------------------------------------------------------
// ProductCategory — 商城商品分类（二级树，CMS / 小程序）
// ---------------------------------------------------------------------------

model ProductCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  imageUrl    String?
  sortOrder   Int      @default(0)
  parentId    String?  @map("parent_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent    ProductCategory?  @relation("ProdCategoryToSub", fields: [parentId], references: [id], onDelete: Cascade)
  children  ProductCategory[] @relation("ProdCategoryToSub")
  products  ProductCategoryRelation[]

  @@index([parentId])
  @@index([sortOrder])
  @@map("product_categories_list")
}

// ---------------------------------------------------------------------------
// ProductCategoryRelation — 商品 ↔ 商品分类（复用原 product_categories 表）
// ---------------------------------------------------------------------------

model ProductCategoryRelation {
  id                String @id @default(uuid())
  productId         String @map("product_id")
  productCategoryId String @map("product_category_id")

  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productCategory ProductCategory @relation(fields: [productCategoryId], references: [id], onDelete: Cascade)

  @@unique([productId, productCategoryId])
  @@index([productCategoryId])
  @@map("product_categories")
}

// ---------------------------------------------------------------------------
// MaterialCategory — WMS 原材料大类（单层扁平，无 parentId）
// ---------------------------------------------------------------------------

model MaterialCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  materials MaterialCategoryRelation[]

  @@index([sortOrder])
  @@map("material_categories")
}

// ---------------------------------------------------------------------------
// MaterialCategoryRelation — 原材料 ↔ 原材料分类
// ---------------------------------------------------------------------------

model MaterialCategoryRelation {
  id                 String @id @default(uuid())
  materialId         String @map("material_id")
  materialCategoryId String @map("material_category_id")

  material         Material         @relation(fields: [materialId], references: [id], onDelete: Cascade)
  materialCategory MaterialCategory @relation(fields: [materialCategoryId], references: [id], onDelete: Cascade)

  @@unique([materialId, materialCategoryId])
  @@index([materialCategoryId])
  @@map("material_category_relations")
}

// ---------------------------------------------------------------------------
// Product — 前台成品花束 / 礼盒
// ---------------------------------------------------------------------------

model Product {
  id              String   @id @default(uuid())
  sku             String   @unique
  name            String
  price           Decimal  @db.Decimal(10, 2)
  costPrice       Decimal? @db.Decimal(10, 2)
  subtitle        String?
  images          String[] @default([])
  detailContent   String?  @db.Text
  status          String   @default("DRAFT")
  quantity        Int      @default(0)
  isOutOfStock    Boolean  @default(false)
  allowPreOrder   Boolean  @default(true)
  productionTime  Int      @default(30)
  shippingFee     Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  categories ProductCategoryRelation[]
  bomItems   ProductBOM[]
  orderItems OrderItem[]

  @@index([status])
  @@map("products")
}

// ---------------------------------------------------------------------------
// Material — 仓储原材料
// ---------------------------------------------------------------------------

model Material {
  id                   String   @id @default(uuid())
  materialCode         String   @unique
  name                 String
  unit                 String
  safetyStockThreshold Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  batches             Batch[]
  stockLogs           StockLog[]
  bomLines            ProductBOM[]
  categoryRelations   MaterialCategoryRelation[]

  @@map("materials")
}

// ---------------------------------------------------------------------------
// ProductBOM — 成品配方
// ---------------------------------------------------------------------------

model ProductBOM {
  id             String @id @default(uuid())
  productId      String
  materialId     String
  quantityNeeded Int

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([productId, materialId])
  @@index([materialId])
  @@map("product_bom")
}

// ---------------------------------------------------------------------------
// Batch — 原材料库存批次（FIFO）
// ---------------------------------------------------------------------------

model Batch {
  id              String    @id @default(cuid())
  materialId      String
  batchNo         String?   @unique
  inboundAt       DateTime  @default(now())
  originalQty     Int
  remainingQty    Int
  unitCost        Decimal   @db.Decimal(12, 4)
  expiresAt       DateTime?
  storageLocation String?
  supplier        String?
  note            String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  material  Material   @relation(fields: [materialId], references: [id], onDelete: Restrict)
  stockLogs StockLog[]

  @@index([materialId, inboundAt])
  @@index([materialId, remainingQty])
  @@index([expiresAt])
  @@map("batches")
}

// ---------------------------------------------------------------------------
// StockLog — 库存变动流水
// ---------------------------------------------------------------------------

model StockLog {
  id            String       @id @default(cuid())
  materialId    String
  batchId       String
  type          StockLogType
  delta         Int
  quantity      Int
  orderId       String?
  orderItemId   String?
  wastageReason String?
  remark        String?      @db.Text
  operator      String?
  createdAt     DateTime     @default(now())

  material  Material   @relation(fields: [materialId], references: [id], onDelete: Restrict)
  batch     Batch      @relation(fields: [batchId], references: [id], onDelete: Restrict)
  order     Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@index([materialId, createdAt])
  @@index([batchId, createdAt])
  @@index([type, createdAt])
  @@index([orderId])
  @@index([orderItemId])
  @@map("stock_logs")
}

// ---------------------------------------------------------------------------
// Order / OrderItem
// ---------------------------------------------------------------------------

model Order {
  id                  String      @id @default(cuid())
  orderNo             String      @unique
  status              OrderStatus @default(PENDING)
  wechatOpenId        String?
  customerName        String?
  customerPhone       String?
  wechatTransactionId String?
  totalAmount         Decimal     @db.Decimal(10, 2)
  receiverName        String?
  receiverPhone       String?
  deliveryAddress     String?     @db.Text
  deliveryTime        DateTime?
  paidAt              DateTime?
  deliveredAt         DateTime?
  remark              String?     @db.Text
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  items     OrderItem[]
  stockLogs StockLog[]

  @@index([status, createdAt])
  @@index([wechatOpenId])
  @@index([orderNo])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productName String
  productSku  String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  stockLogs StockLog[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ---------------------------------------------------------------------------
// AppConfig
// ---------------------------------------------------------------------------

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_configs")
}

// =============================================================================
// Flower WMS — 花店仓库管理与微信小程序订单
// 架构：Product（前台成品）↔ ProductBOM ↔ Material（仓储原材料）+ Batch FIFO
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// 库存流水类型
enum StockLogType {
  INBOUND /// 采购入库（增加批次可用量）
  SALE_OUT /// 销售出库（FIFO 扣减）
  WASTAGE_OUT /// 损耗出库（FIFO 扣减）
  ADJUSTMENT /// 盘点调整（可正可负）
  IN_CANCEL /// 订单取消释放库存（对冲下单锁库）
}

/// 微信订单状态
enum OrderStatus {
  PENDING /// 待付款（已锁库计划，未正式扣减）
  PAID /// 已付款
  PREPARING /// 制作中
  DELIVERED /// 已送达
  CANCELLED /// 已取消
}

// ---------------------------------------------------------------------------
// Category — 前台商品分类（营销维度）
// ---------------------------------------------------------------------------

model Category {
  id        String   @id @default(uuid())
  key       String   @unique /// 分类键，如 bouquet、qixi
  name      String /// 展示名称，如「经典手捧」「七夕专区」
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products ProductCategory[]

  @@map("categories")
}

// ---------------------------------------------------------------------------
// ProductCategory — 商品与分类多对多纽带
// ---------------------------------------------------------------------------

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
  @@map("product_categories")
}

// ---------------------------------------------------------------------------
// Product — 前台成品花束 / 礼盒（营销与订单核心，不含仓储批次）
// ---------------------------------------------------------------------------

model Product {
  id              String   @id @default(uuid())
  sku             String   @unique /// 物料编码，如 BOUQUET-ROSE-11
  name            String
  price           Decimal  @db.Decimal(10, 2) /// 标准零售价
  costPrice       Decimal? @db.Decimal(10, 2) /// 参考成本价
  subtitle        String? /// 前台一句话情话
  images          String[] @default([]) /// 主图 / 轮播图
  detailContent   String?  @db.Text /// 富文本 / 长图介绍
  /// 状态：DRAFT | PUBLISHED | ARCHIVED
  status          String   @default("DRAFT")
  quantity        Int      @default(0) /// 可售数量（前台展示与下单扣减）
  isOutOfStock    Boolean  @default(false) /// 人工一键售罄
  allowPreOrder   Boolean  @default(true) /// 今日售罄后是否允许预约明日
  productionTime  Int      @default(30) /// 预计手工制作耗时（分钟）
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  categories ProductCategory[]
  bomItems   ProductBOM[]
  orderItems OrderItem[]

  @@index([status])
  @@map("products")
}

// ---------------------------------------------------------------------------
// Material — 仓储原材料（花材、包装、辅料），不含营销字段
// ---------------------------------------------------------------------------

model Material {
  id                   String   @id @default(uuid())
  materialCode         String   @unique /// 原材料编码，如 MAT-ROSE-RED
  name                 String
  unit                 String /// 计量单位：枝、张、卷
  safetyStockThreshold Int      @default(0) /// 安全库存预警阈值
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  batches   Batch[]
  stockLogs StockLog[]
  bomLines  ProductBOM[]

  @@map("materials")
}

// ---------------------------------------------------------------------------
// ProductBOM — 成品配方：一束商品由哪些原材料及用量组成
// ---------------------------------------------------------------------------

model ProductBOM {
  id             String @id @default(uuid())
  productId      String
  materialId     String
  quantityNeeded Int /// 单件成品所需原材料数量

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([productId, materialId])
  @@index([materialId])
  @@map("product_bom")
}

// ---------------------------------------------------------------------------
// Batch — 原材料库存批次（FIFO 核心，仅挂在 Material）
// ---------------------------------------------------------------------------

model Batch {
  id              String    @id @default(cuid())
  materialId      String
  batchNo         String?   @unique /// 批次号，如 PO-20260522-001
  inboundAt       DateTime  @default(now()) /// 入库时间，FIFO 排序依据
  originalQty     Int /// 采购入库原始数量
  remainingQty    Int /// 当前可用剩余数量（出库递减，≥ 0）
  unitCost        Decimal   @db.Decimal(12, 4) /// 进货单价（按批次核算成本）
  expiresAt       DateTime? /// 瓶插期 / 预计枯萎截止日
  storageLocation String? /// 库位，如 冷库 A-01
  supplier        String? /// 供应商
  note            String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  material  Material   @relation(fields: [materialId], references: [id], onDelete: Restrict)
  stockLogs StockLog[]

  /// FIFO: WHERE materialId = ? AND remainingQty > 0 ORDER BY inboundAt ASC
  @@index([materialId, inboundAt])
  @@index([materialId, remainingQty])
  @@index([expiresAt])
  @@map("batches")
}

// ---------------------------------------------------------------------------
// StockLog — 库存变动流水（绑定原材料批次）
// ---------------------------------------------------------------------------

model StockLog {
  id            String       @id @default(cuid())
  materialId    String
  batchId       String
  type          StockLogType
  /// 变动量：入库/盘盈为正，销售/损耗/盘亏为负
  delta         Int
  /// 本条流水绝对数量（展示用，恒为正）
  quantity      Int
  orderId       String? /// 销售出库关联订单
  orderItemId   String? /// 销售出库关联订单行
  wastageReason String? /// 损耗原因
  remark        String?      @db.Text
  operator      String? /// 操作人 / system
  createdAt     DateTime     @default(now())

  material  Material   @relation(fields: [materialId], references: [id], onDelete: Restrict)
  batch     Batch      @relation(fields: [batchId], references: [id], onDelete: Restrict)
  order     Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@index([materialId, createdAt])
  @@index([batchId, createdAt])
  @@index([type, createdAt])
  @@index([orderId])
  @@index([orderItemId])
  @@map("stock_logs")
}

// ---------------------------------------------------------------------------
// Order / OrderItem — 微信小程序订单（行项目指向 Product）
// ---------------------------------------------------------------------------

model Order {
  id                  String      @id @default(cuid())
  orderNo             String      @unique /// 业务单号，如 FL20260522001
  status              OrderStatus @default(PENDING)
  wechatOpenId        String?
  customerName        String?
  customerPhone       String?
  wechatTransactionId String? /// 微信支付单号
  totalAmount         Decimal     @db.Decimal(10, 2)
  /// 配送信息
  receiverName        String?
  receiverPhone       String?
  deliveryAddress     String?     @db.Text
  deliveryTime        DateTime? /// 顾客预约送达时间
  paidAt              DateTime?
  deliveredAt         DateTime?
  remark              String?     @db.Text
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  items     OrderItem[]
  stockLogs StockLog[]

  @@index([status, createdAt])
  @@index([wechatOpenId])
  @@index([orderNo])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  /// 下单快照，避免后续改名影响历史订单
  productName String
  productSku  String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  stockLogs StockLog[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ---------------------------------------------------------------------------
// AppConfig — 小程序运营配置（轮播、营销等，value 为 JSON）
// ---------------------------------------------------------------------------

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique /// 如 HOME_BANNER
  name      String /// 后台展示名称
  value     Json /// 配置载荷，如轮播图数组
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_configs")
}

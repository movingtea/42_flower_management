// =============================================================================
// Flower WMS — 花店仓库管理与微信小程序订单
// 架构：Recipe（WMS 标准配方）↔ ProductSku（每规格可选绑定）；RecipeLine ↔ FlowerWiki
// 商品分类与原材料分类完全解耦，各自独立表与中间表
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// 库存流水类型
enum StockLogType {
  INBOUND /// 采购入库（增加批次可用量）
  SALE_OUT /// 销售出库（FIFO 扣减）
  WASTAGE_OUT /// 损耗出库（FIFO 扣减）
  ADJUSTMENT /// 盘点调整（可正可负）
  IN_CANCEL /// 订单取消释放库存（对冲下单锁库）
}

/// 微信订单履约状态机
enum OrderStatus {
  PENDING_PAYMENT /// 待支付
  PAID /// 已支付 / 待制作
  PRODUCTION /// 制作中
  DELIVERING /// 配送中
  COMPLETED /// 已完成
  CANCELLED /// 已取消
}

/// 取消来源（归档色彩语义）
enum OrderCancelSource {
  CUSTOMER /// 顾客在待支付阶段取消
  ADMIN /// 店长关闭待支付订单
  REFUND /// 已付/制作中退款取消
}

/// CRM 客户来源
enum CustomerSource {
  MINI_PROGRAM
  WECHAT
  XIAOHONGSHU
  DOUYIN
  FRIEND_REFERRAL
  OFFLINE
  MANUAL
  OTHER
}

/// 购买人与收花人关系
enum RecipientRelationType {
  SELF
  PARTNER
  MOTHER
  FATHER
  FAMILY
  FRIEND
  COLLEAGUE
  CLIENT
  TEACHER
  OTHER
}

/// 礼赠场景类型
enum GiftOccasionType {
  BIRTHDAY
  ANNIVERSARY
  VALENTINE
  QIXI
  MOTHERS_DAY
  GRADUATION
  VISIT
  APOLOGY
  BUSINESS
  OPENING
  WEDDING
  DAILY_SURPRISE
  OTHER
}

/// 复购提醒类型
enum ReminderType {
  BIRTHDAY
  ANNIVERSARY
  FOLLOW_UP
  FESTIVAL
  CUSTOM
}

/// 复购提醒状态
enum ReminderStatus {
  PENDING
  DONE
  SNOOZED
  CANCELLED
}

/// CMS 推荐位类型
enum RecommendationSlotType {
  HOME_MAIN
  HOME_SECONDARY
  SCENE
  FESTIVAL
  NEW_ARRIVAL
  HIGH_TICKET
  CUSTOM
}

/// 首页轮播跳转类型
enum BannerTargetType {
  PRODUCT /// 跳转商城商品详情
  ACTIVITY /// 跳转活动页（targetParam 为路径或页面标识）
  COUPON /// 跳转优惠券（targetParam 为券 ID 或活动码）
  NONE /// 仅展示，不跳转
}

/// 花艺核心角色
enum FloralRole {
  MAIN /// 主花
  FILLER /// 配花
  LINE /// 线条花
  FOLIAGE /// 叶材
}

/// 供应商类型
enum SupplierType {
  LOCAL /// 本地花农 / 门店周边供应
  KUNMING_ONLINE /// 昆明线上采购
  WHOLESALE_MARKET /// 批发市场
  PLATFORM /// 平台采购
  OTHER /// 其他
}

/// 采购单状态
enum PurchaseOrderStatus {
  DRAFT /// 草稿
  ORDERED /// 已下单
  RECEIVED /// 已到货入库
  CANCELLED /// 已取消
}

/// 采购附加成本分摊方式
enum PurchaseCostAllocationMethod {
  BY_AMOUNT /// 按明细金额占比分摊
  BY_QUANTITY /// 按采购数量占比分摊（预留）
}

/// 损耗成本估算档位
enum LossMode {
  OPTIMISTIC /// 乐观可用率
  STANDARD /// 标准可用率
  CONSERVATIVE /// 保守可用率
}

/// 后台员工 RBAC 五级角色（与小程序 users 表解耦）
enum Role {
  IT_ADMIN /// 系统运维：仅用户/权限，业务盲区
  STORE_ADMIN /// 门店主理人：WMS + CMS + 人员 + 全量损耗审计
  WAREHOUSE_MANAGER /// 大仓：入库、报损、Wiki、配方审定
  FLORIST /// 花艺师：订单看板 + Wiki/配方只读
  STORE_OPERATOR /// 前台：CMS 商品上架，配方只读引用
}

/// 后台账号管理审计动作
enum StaffAuditAction {
  PASSWORD_RESET /// 管理员代行重置密码
}

// ---------------------------------------------------------------------------
// ProductCategory — 商城商品分类（二级树，CMS / 小程序）
// ---------------------------------------------------------------------------

model ProductCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  imageUrl    String?
  sortOrder   Int      @default(0)
  parentId    String?  @map("parent_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   ProductCategory?          @relation("ProdCategoryToSub", fields: [parentId], references: [id], onDelete: Cascade)
  children ProductCategory[]         @relation("ProdCategoryToSub")
  products ProductCategoryRelation[]

  @@index([parentId])
  @@index([sortOrder])
  @@map("product_categories_list")
}

// ---------------------------------------------------------------------------
// ProductCategoryRelation — 商品 ↔ 商品分类（复用原 product_categories 表）
// ---------------------------------------------------------------------------

model ProductCategoryRelation {
  id                String @id @default(uuid())
  spuId             String @map("product_id")
  productCategoryId String @map("product_category_id")

  spu             ProductSpu      @relation(fields: [spuId], references: [id], onDelete: Cascade)
  productCategory ProductCategory @relation(fields: [productCategoryId], references: [id], onDelete: Cascade)

  @@unique([spuId, productCategoryId])
  @@index([productCategoryId])
  @@map("product_categories")
}

// ---------------------------------------------------------------------------
// MaterialCategory — WMS 原材料大类（单层扁平，无 parentId）
// ---------------------------------------------------------------------------

model MaterialCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  materials MaterialCategoryRelation[]

  @@index([sortOrder])
  @@map("material_categories")
}

// ---------------------------------------------------------------------------
// MaterialCategoryRelation — 原材料 ↔ 原材料分类
// ---------------------------------------------------------------------------

model MaterialCategoryRelation {
  id                 String @id @default(uuid())
  materialId         String @map("material_id")
  materialCategoryId String @map("material_category_id")

  material         Material         @relation(fields: [materialId], references: [id], onDelete: Cascade)
  materialCategory MaterialCategory @relation(fields: [materialCategoryId], references: [id], onDelete: Cascade)

  @@unique([materialId, materialCategoryId])
  @@index([materialCategoryId])
  @@map("material_category_relations")
}

// ---------------------------------------------------------------------------
// Supplier / PurchaseOrder — 供应商与采购单（采购成本分摊 + 到货入库）
// ---------------------------------------------------------------------------

model Supplier {
  id           String       @id @default(cuid())
  name         String
  supplierType SupplierType @map("supplier_type")
  contactName  String?      @map("contact_name")
  phone        String?
  wechat       String?
  address      String?      @db.Text
  note         String?      @db.Text
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  purchaseOrders PurchaseOrder[]

  @@index([name])
  @@index([supplierType])
  @@index([isActive])
  @@map("suppliers")
}

model PurchaseOrder {
  id                  String                       @id @default(cuid())
  purchaseNo          String                       @unique @map("purchase_no")
  supplierId          String                       @map("supplier_id")
  purchaseDate        DateTime                     @map("purchase_date")
  expectedArrivalDate DateTime?                    @map("expected_arrival_date")
  receivedAt          DateTime?                    @map("received_at")
  status              PurchaseOrderStatus          @default(DRAFT)
  goodsAmount         Decimal                      @default(0) @map("goods_amount") @db.Decimal(12, 2)
  shippingFee         Decimal                      @default(0) @map("shipping_fee") @db.Decimal(12, 2)
  packagingFee        Decimal                      @default(0) @map("packaging_fee") @db.Decimal(12, 2)
  otherFee            Decimal                      @default(0) @map("other_fee") @db.Decimal(12, 2)
  totalExtraFee       Decimal                      @default(0) @map("total_extra_fee") @db.Decimal(12, 2)
  totalAmount         Decimal                      @default(0) @map("total_amount") @db.Decimal(12, 2)
  allocationMethod    PurchaseCostAllocationMethod @default(BY_AMOUNT) @map("allocation_method")
  note                String?                      @db.Text
  createdAt           DateTime                     @default(now()) @map("created_at")
  updatedAt           DateTime                     @updatedAt @map("updated_at")

  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  lines    PurchaseOrderLine[]

  @@index([supplierId])
  @@index([purchaseDate])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id                String   @id @default(cuid())
  purchaseOrderId   String   @map("purchase_order_id")
  flowerWikiId      String   @map("flower_wiki_id")
  purchaseName      String?  @map("purchase_name")
  grade             String?
  color             String?
  spec              String?
  purchaseQuantity  Decimal  @map("purchase_quantity") @db.Decimal(12, 2)
  purchaseUnit      String   @map("purchase_unit")
  stemsPerUnit      Decimal  @map("stems_per_unit") @db.Decimal(12, 2)
  totalStems        Decimal  @map("total_stems") @db.Decimal(12, 2)
  unitPrice         Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineAmount        Decimal  @map("line_amount") @db.Decimal(12, 2)
  allocatedExtraFee Decimal  @default(0) @map("allocated_extra_fee") @db.Decimal(12, 2)
  actualTotalCost        Decimal  @default(0) @map("actual_total_cost") @db.Decimal(12, 2)
  actualUnitCost         Decimal  @default(0) @map("actual_unit_cost") @db.Decimal(12, 4)
  usableRate             Decimal? @map("usable_rate") @db.Decimal(5, 4)
  lossRate               Decimal? @map("loss_rate") @db.Decimal(5, 4)
  lossAdjustedTotalCost  Decimal? @map("loss_adjusted_total_cost") @db.Decimal(12, 2)
  lossAdjustedUnitCost   Decimal? @map("loss_adjusted_unit_cost") @db.Decimal(12, 4)
  supplierSkuName        String?  @map("supplier_sku_name")
  note              String?  @db.Text
  inboundBatchId    String?  @unique @map("inbound_batch_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  flowerWiki    FlowerWiki    @relation(fields: [flowerWikiId], references: [id], onDelete: Restrict)
  inboundBatch  Batch?        @relation("PurchaseLineInboundBatch", fields: [inboundBatchId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([flowerWikiId])
  @@map("purchase_order_lines")
}

// ---------------------------------------------------------------------------
// ProductSpu / ProductSku — 一维单款式（SPU 公用信息 + SKU 款式）
// ---------------------------------------------------------------------------

model ProductSpu {
  id               String   @id @default(uuid())
  name             String
  description      String?  @db.Text
  maintenanceGuide String?  @map("maintenance_guide") @db.Text
  isActive         Boolean  @default(false) @map("is_active")
  isDeleted        Boolean  @default(false) @map("is_deleted")
  shippingFee      Float    @default(0) @map("shipping_fee")
  allowPreOrder    Boolean  @default(true) @map("allow_pre_order")
  productionTime   Int      @default(30) @map("production_time")
  /// 适用礼赠场景标签（GiftOccasionType key 列表）
  occasionTags     String[] @default([]) @map("occasion_tags")
  /// 色系标签（英文 key 数组，JSON 存储）
  colorTags        Json?    @map("color_tags")
  /// 风格标签
  styleTags        Json?    @map("style_tags")
  /// 适合关系标签
  relationshipTags Json?    @map("relationship_tags")
  /// 预算区间标签
  budgetTags       Json?    @map("budget_tags")
  /// 商品定位标签
  positioningTags  Json?    @map("positioning_tags")
  /// 卖点短语数组
  sellingPoints    Json?    @map("selling_points")
  /// 运营内部备注（不返回小程序前台）
  operationNote    String?  @map("operation_note") @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  skus                 ProductSku[]
  categories           ProductCategoryRelation[]
  banners              Banner[]
  recommendationItems  CmsRecommendationItem[]

  @@index([isActive])
  @@index([isDeleted])
  @@map("product_spus")
}

model ProductSku {
  id          String   @id @default(uuid())
  spuId       String   @map("spu_id")
  skuCode     String   @unique @map("sku_code")
  specName    String   @map("spec_name")
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  recipeId    String?  @map("recipe_id")
  description String?  @db.Text
  imageUrl    String?  @map("image_url")
  isMainImage Boolean  @default(false) @map("is_main_image")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  spu                  ProductSpu              @relation(fields: [spuId], references: [id], onDelete: Cascade)
  recipe               Recipe?                 @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  orderItems           OrderItem[]
  recommendationItems  CmsRecommendationItem[]

  @@index([spuId])
  @@index([spuId, isMainImage])
  @@index([recipeId])
  @@map("product_skus")
}

// ---------------------------------------------------------------------------
// CmsRecommendationSlot / CmsRecommendationItem — 小程序推荐位人工配置
// ---------------------------------------------------------------------------

model CmsRecommendationSlot {
  id          String                 @id @default(cuid())
  key         String                 @unique
  name        String
  description String?                @db.Text
  slotType    RecommendationSlotType @map("slot_type")
  sceneType   GiftOccasionType?      @map("scene_type")
  isActive    Boolean                @default(true) @map("is_active")
  sortOrder   Int                    @default(0) @map("sort_order")
  maxItems    Int                    @default(10) @map("max_items")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  items CmsRecommendationItem[]

  @@index([slotType])
  @@index([isActive])
  @@index([sortOrder])
  @@map("cms_recommendation_slots")
}

model CmsRecommendationItem {
  id               String    @id @default(cuid())
  slotId           String    @map("slot_id")
  productId        String    @map("product_id")
  skuId            String?   @map("sku_id")
  titleOverride    String?   @map("title_override")
  subtitleOverride String?   @map("subtitle_override")
  imageOverride    String?   @map("image_override")
  sortOrder        Int       @default(0) @map("sort_order")
  isActive         Boolean   @default(true) @map("is_active")
  startAt          DateTime? @map("start_at")
  endAt            DateTime? @map("end_at")
  note             String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  slot    CmsRecommendationSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  product ProductSpu            @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku     ProductSku?           @relation(fields: [skuId], references: [id], onDelete: SetNull)

  @@index([slotId])
  @@index([productId])
  @@index([skuId])
  @@index([isActive])
  @@index([sortOrder])
  @@index([startAt])
  @@index([endAt])
  @@map("cms_recommendation_items")
}

// ---------------------------------------------------------------------------
// Banner — 首页轮播（与商品解耦，支持多场景跳转）
// ---------------------------------------------------------------------------

model Banner {
  id          String           @id @default(uuid())
  imageUrl    String           @map("image_url")
  sortOrder   Int              @default(100) @map("sort_order")
  targetType  BannerTargetType @default(NONE) @map("target_type")
  targetParam String?          @map("target_param")
  productId   String?          @map("product_id")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  spu ProductSpu? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([sortOrder])
  @@index([isActive])
  @@index([targetType])
  @@map("banners")
}

// ---------------------------------------------------------------------------
// Material — 仓储原材料
// ---------------------------------------------------------------------------

model Material {
  id                   String   @id @default(uuid())
  materialCode         String   @unique
  name                 String
  unit                 String
  safetyStockThreshold Int      @default(0)
  wikiId               String?  @map("wiki_id")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  wiki              FlowerWiki?                @relation(fields: [wikiId], references: [id])
  batches           Batch[]
  stockLogs         StockLog[]
  categoryRelations MaterialCategoryRelation[]

  @@index([wikiId])
  @@map("materials")
}

// ---------------------------------------------------------------------------
// Recipe — WMS 独立标准工艺配方（大仓黄金标准）
// ---------------------------------------------------------------------------

model Recipe {
  id             String   @id @default(uuid())
  recipeCode     String   @unique @map("recipe_code")
  name           String
  description    String?  @db.Text
  packagingKitId String?  @map("packaging_kit_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  lines        RecipeLine[]
  skus         ProductSku[]
  packagingKit PackagingKit? @relation(fields: [packagingKitId], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([packagingKitId])
  @@map("recipes")
}

model PackagingKit {
  id           String   @id @default(uuid())
  name         String
  description  String?  @db.Text
  standardCost Decimal  @map("standard_cost") @db.Decimal(10, 2)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  recipes Recipe[]

  @@index([isActive])
  @@index([updatedAt])
  @@map("packaging_kits")
}

model RecipeLine {
  id             String @id @default(uuid())
  recipeId       String @map("recipe_id")
  flowerWikiId   String @map("flower_wiki_id")
  quantityNeeded Int    @map("quantity_needed")

  recipe Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  wiki   FlowerWiki @relation(fields: [flowerWikiId], references: [id], onDelete: Restrict)

  @@unique([recipeId, flowerWikiId])
  @@index([flowerWikiId])
  @@map("recipe_lines")
}

// ---------------------------------------------------------------------------
// Batch — 原材料库存批次（FIFO）
// ---------------------------------------------------------------------------

model Batch {
  id              String    @id @default(cuid())
  materialId      String
  batchNo         String?   @unique
  inboundAt       DateTime  @default(now())
  originalQty            Int
  remainingQty           Int
  unitCost               Decimal   @db.Decimal(12, 4)
  lossAdjustedUnitCost   Decimal?  @map("loss_adjusted_unit_cost") @db.Decimal(12, 4)
  usableRate             Decimal?  @map("usable_rate") @db.Decimal(5, 4)
  lossRate               Decimal?  @map("loss_rate") @db.Decimal(5, 4)
  expiresAt              DateTime?
  storageLocation String?
  supplier        String?
  note            String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  material          Material           @relation(fields: [materialId], references: [id], onDelete: Restrict)
  stockLogs         StockLog[]
  stockLossRecords  StockLossRecord[]
  purchaseOrderLine PurchaseOrderLine? @relation("PurchaseLineInboundBatch")

  @@index([materialId, inboundAt])
  @@index([materialId, remainingQty])
  @@index([expiresAt])
  @@map("batches")
}

// ---------------------------------------------------------------------------
// StockLog — 库存变动流水
// ---------------------------------------------------------------------------

model StockLog {
  id              String       @id @default(cuid())
  materialId      String
  batchId         String
  type            StockLogType
  delta           Int
  quantity        Int
  orderId         String?
  orderItemId     String?
  wastageReason   String?
  remark          String?      @db.Text
  operator        String? /// 操作员快照（username）
  operatorStaffId String?      @map("operator_staff_id")
  createdAt       DateTime     @default(now())

  material        Material         @relation(fields: [materialId], references: [id], onDelete: Restrict)
  batch           Batch            @relation(fields: [batchId], references: [id], onDelete: Restrict)
  order           Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItem       OrderItem?       @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  operatorStaff   StaffUser?       @relation(fields: [operatorStaffId], references: [id], onDelete: SetNull)
  stockLossRecord StockLossRecord?

  @@index([materialId, createdAt])
  @@index([batchId, createdAt])
  @@index([type, createdAt])
  @@index([orderId])
  @@index([orderItemId])
  @@index([operatorStaffId])
  @@map("stock_logs")
}

// ---------------------------------------------------------------------------
// StockLossRecord — 大仓物理报损留痕（关联母表 + 指定批次）
// ---------------------------------------------------------------------------

model StockLossRecord {
  id              String   @id @default(cuid())
  flowerWikiId    String   @map("flower_wiki_id")
  batchId         String   @map("batch_id")
  lossQuantity    Int      @map("loss_quantity")
  reason          String   @db.Text
  operator        String? /// 操作员快照（username）
  operatorStaffId String?  @map("operator_staff_id")
  stockLogId      String   @unique @map("stock_log_id")
  createdAt       DateTime @default(now()) @map("created_at")

  wiki          FlowerWiki @relation(fields: [flowerWikiId], references: [id], onDelete: Restrict)
  batch         Batch      @relation(fields: [batchId], references: [id], onDelete: Restrict)
  stockLog      StockLog   @relation(fields: [stockLogId], references: [id], onDelete: Restrict)
  operatorStaff StaffUser? @relation(fields: [operatorStaffId], references: [id], onDelete: SetNull)

  @@index([flowerWikiId, createdAt])
  @@index([batchId, createdAt])
  @@index([operatorStaffId])
  @@map("stock_loss_records")
}

// ---------------------------------------------------------------------------
// StaffUser — 后台登录账号（Credentials + RBAC）
// 说明：小程序顾客仍使用下方 User（openId），二者物理隔离
// ---------------------------------------------------------------------------

model StaffUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         Role
  displayName  String?  @map("display_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  stockLogs        StockLog[]
  stockLossRecords StockLossRecord[]
  auditsAsOperator StaffAuditLog[]   @relation("StaffAuditOperator")
  auditsAsTarget   StaffAuditLog[]   @relation("StaffAuditTarget")

  @@index([role])
  @@map("staff_users")
}

// ---------------------------------------------------------------------------
// StaffAuditLog — 后台账号操作审计（密码重置等）
// ---------------------------------------------------------------------------

model StaffAuditLog {
  id              String           @id @default(uuid())
  action          StaffAuditAction
  operatorStaffId String           @map("operator_staff_id")
  targetStaffId   String           @map("target_staff_id")
  createdAt       DateTime         @default(now()) @map("created_at")

  operator StaffUser @relation("StaffAuditOperator", fields: [operatorStaffId], references: [id], onDelete: Restrict)
  target   StaffUser @relation("StaffAuditTarget", fields: [targetStaffId], references: [id], onDelete: Restrict)

  @@index([operatorStaffId, createdAt])
  @@index([targetStaffId, createdAt])
  @@index([action, createdAt])
  @@map("staff_audit_logs")
}

// ---------------------------------------------------------------------------
// User — 小程序用户（OpenID 主键体系）
// ---------------------------------------------------------------------------

model User {
  id                   String   @id @default(uuid())
  openId               String   @unique @map("open_id")
  nickName             String?  @map("nick_name")
  avatarUrl            String?  @map("avatar_url")
  defaultReceiverName  String?  @map("default_receiver_name")
  defaultReceiverPhone String?  @map("default_receiver_phone")
  defaultAddress       String?  @map("default_address") @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  orders   Order[]
  customer Customer?

  @@map("users")
}

// ---------------------------------------------------------------------------
// Order / OrderItem
// ---------------------------------------------------------------------------

model Order {
  id                 String             @id @default(uuid())
  orderNo            String             @unique @map("order_no")
  userId             String             @map("user_id")
  totalAmount        Float              @map("total_amount")
  deliveryFee        Float              @default(0) @map("delivery_fee")
  payAmount          Float              @map("pay_amount")
  receiverName       String             @map("receiver_name")
  receiverPhone      String             @map("receiver_phone")
  deliveryAddress    String             @map("delivery_address") @db.Text
  deliveryDate       String             @map("delivery_date")
  greetingCard       String?            @map("greeting_card") @db.Text
  deliveryInfo       String?            @map("delivery_info") @db.Text
  status             OrderStatus        @default(PENDING_PAYMENT)
  paidAt             DateTime?          @map("paid_at")
  refundAmount       Float?             @map("refund_amount")
  refundTime         DateTime?          @map("refund_time")
  cancelSource       OrderCancelSource? @map("cancel_source")
  deliveryCostActual Decimal?           @default(0) @map("delivery_cost_actual") @db.Decimal(10, 2)
  deliveryCostNote   String?            @map("delivery_cost_note") @db.Text
  customerId         String?            @map("customer_id")
  recipientId        String?            @map("recipient_id")
  giftOccasionId     String?            @map("gift_occasion_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  customer     Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  recipient    Recipient?         @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  giftOccasion GiftOccasion?      @relation(fields: [giftOccasionId], references: [id], onDelete: SetNull)
  items        OrderItem[]
  stockLogs    StockLog[]
  costSnapshot OrderCostSnapshot?

  @@index([status, createdAt])
  @@index([userId])
  @@index([orderNo])
  @@index([customerId])
  @@map("orders")
}

model OrderCostSnapshot {
  id                 String   @id @default(uuid())
  orderId            String   @unique @map("order_id")
  paidAmount         Decimal  @map("paid_amount") @db.Decimal(10, 2)
  flowerMaterialCost Decimal  @map("flower_material_cost") @db.Decimal(10, 2)
  packagingCost      Decimal  @map("packaging_cost") @db.Decimal(10, 2)
  deliveryCostActual Decimal  @default(0) @map("delivery_cost_actual") @db.Decimal(10, 2)
  platformFee        Decimal  @default(0) @map("platform_fee") @db.Decimal(10, 2)
  floristLaborCost   Decimal  @default(0) @map("florist_labor_cost") @db.Decimal(10, 2)
  otherCost          Decimal  @default(0) @map("other_cost") @db.Decimal(10, 2)
  totalCost          Decimal  @map("total_cost") @db.Decimal(10, 2)
  grossProfit        Decimal  @map("gross_profit") @db.Decimal(10, 2)
  grossMargin        Decimal  @map("gross_margin") @db.Decimal(10, 4)
  costCalculatedAt   DateTime @map("cost_calculated_at")
  costVersion        String   @default("v1") @map("cost_version")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([costCalculatedAt])
  @@map("order_cost_snapshots")
}

model OrderItem {
  id                  String   @id @default(uuid())
  orderId             String   @map("order_id")
  skuId               String   @map("sku_id")
  quantity            Int
  snapshotProductName String   @map("snapshot_product_name")
  snapshotSpecName    String   @map("snapshot_spec_name")
  snapshotPrice       Float    @map("snapshot_price")
  snapshotImageUrl    String   @map("snapshot_image_url")
  createdAt           DateTime @default(now()) @map("created_at")

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku       ProductSku @relation(fields: [skuId], references: [id], onDelete: Restrict)
  stockLogs StockLog[]

  @@index([orderId])
  @@index([skuId])
  @@map("order_items")
}

// ---------------------------------------------------------------------------
// CRM — 小程序订单驱动的客户关系
// ---------------------------------------------------------------------------

model Customer {
  id               String         @id @default(cuid())
  miniProgramUserId String?       @unique @map("mini_program_user_id")
  name             String?
  phone            String?
  wechatNickname   String?        @map("wechat_nickname")
  wechatOpenid     String?        @map("wechat_openid")
  wechatUnionid    String?        @map("wechat_unionid")
  source           CustomerSource @default(MINI_PROGRAM)
  note             String?        @db.Text
  tags             String[]       @default([])
  firstOrderAt     DateTime?      @map("first_order_at")
  lastOrderAt      DateTime?      @map("last_order_at")
  totalOrders      Int            @default(0) @map("total_orders")
  totalSpent       Decimal        @default(0) @map("total_spent") @db.Decimal(12, 2)
  averageOrderValue Decimal       @default(0) @map("average_order_value") @db.Decimal(12, 2)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  miniProgramUser User?                      @relation(fields: [miniProgramUserId], references: [id], onDelete: SetNull)
  recipientRelations CustomerRecipientRelation[]
  occasions      GiftOccasion[]
  reminders      CustomerReminder[]
  orders         Order[]

  @@index([phone])
  @@index([wechatOpenid])
  @@index([source])
  @@index([lastOrderAt])
  @@map("customers")
}

model Recipient {
  id               String    @id @default(cuid())
  name             String
  phone            String?
  address          String?   @db.Text
  birthday         DateTime?
  preferredColors  String?   @map("preferred_colors")
  dislikedFlowers  String?   @map("disliked_flowers")
  preferenceNote   String?   @map("preference_note") @db.Text
  note             String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  customerRelations CustomerRecipientRelation[]
  occasions         GiftOccasion[]
  reminders         CustomerReminder[]
  orders            Order[]

  @@index([phone])
  @@index([name])
  @@map("recipients")
}

model CustomerRecipientRelation {
  id            String                 @id @default(cuid())
  customerId    String                 @map("customer_id")
  recipientId   String                 @map("recipient_id")
  relationType  RecipientRelationType? @map("relation_type")
  relationLabel String?                @map("relation_label")
  isDefault     Boolean                @default(false) @map("is_default")
  isActive      Boolean                @default(true) @map("is_active")
  source        CustomerSource         @default(MINI_PROGRAM)
  lastUsedAt    DateTime?              @map("last_used_at")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  recipient Recipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  occasions GiftOccasion[]

  @@unique([customerId, recipientId])
  @@index([customerId])
  @@index([recipientId])
  @@index([customerId, recipientId])
  @@map("customer_recipient_relations")
}

model GiftOccasion {
  id                  String           @id @default(cuid())
  customerId          String?          @map("customer_id")
  recipientId         String?          @map("recipient_id")
  relationId          String?          @map("relation_id")
  orderId             String?          @map("order_id")
  occasionType        GiftOccasionType @map("occasion_type")
  occasionLabel       String?          @map("occasion_label")
  importantDate       DateTime?        @map("important_date")
  giftPurpose         String?          @map("gift_purpose")
  cardMessage         String?          @map("card_message") @db.Text
  preferenceSnapshot  Json?            @map("preference_snapshot")
  note                String?          @db.Text
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  customer  Customer?                  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  recipient Recipient?                 @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  relation  CustomerRecipientRelation? @relation(fields: [relationId], references: [id], onDelete: SetNull)
  orders    Order[]
  reminders CustomerReminder[]

  @@index([customerId])
  @@index([recipientId])
  @@index([orderId])
  @@index([occasionType])
  @@index([importantDate])
  @@map("gift_occasions")
}

model CustomerReminder {
  id           String         @id @default(cuid())
  customerId   String         @map("customer_id")
  recipientId  String?        @map("recipient_id")
  occasionId   String?        @map("occasion_id")
  orderId      String?        @map("order_id")
  type         ReminderType
  status       ReminderStatus @default(PENDING)
  title        String
  content      String?        @db.Text
  remindAt     DateTime       @map("remind_at")
  dueDate      DateTime?      @map("due_date")
  completedAt  DateTime?      @map("completed_at")
  snoozedUntil DateTime?      @map("snoozed_until")
  note         String?        @db.Text
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  customer  Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  recipient Recipient?    @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  occasion  GiftOccasion? @relation(fields: [occasionId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([recipientId])
  @@index([status])
  @@index([remindAt])
  @@index([type])
  @@map("customer_reminders")
}

// ---------------------------------------------------------------------------
// AppConfig
// ---------------------------------------------------------------------------

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_configs")
}

// ---------------------------------------------------------------------------
// FlowerWiki — 基础物料母表 / 数字化智库
// ---------------------------------------------------------------------------

model FlowerWiki {
  id                   String     @id @default(uuid())
  photo                String?
  englishName          String     @unique @map("english_name")
  chineseName          String     @map("chinese_name")
  pinyinIndex          String     @default("") @map("pinyin_index")
  colorTags            String[]   @default([]) @map("color_tags")
  morphology           String?
  supplySeason         String?    @map("supply_season")
  floralRole           FloralRole @map("floral_role")
  maintenance          String     @db.Text
  flowerLanguage       String?    @map("flower_language") @db.Text
  /// 结构化养护指南表格（AI / 表格编辑）；maintenance 保留文本摘要兼容旧数据
  maintenanceCare      Json?      @map("maintenance_care")
  /// 默认保质期（天）；入库时用于计算 batch.expiresAt，可单次入库覆盖
  defaultShelfLifeDays Int?       @map("default_shelf_life_days")
  /// 标准单支成本：仅用于产品定价预估；订单实际成本仍以 Batch.unitCost 为准
  standardUnitCost       Decimal?   @map("standard_unit_cost") @db.Decimal(12, 4)
  costUnit               String?    @map("cost_unit")
  costUpdatedAt          DateTime?  @map("cost_updated_at")
  costNote               String?    @map("cost_note") @db.Text
  /// 默认可用率（0–1）；用于采购损耗成本摊分
  defaultUsableRate      Decimal?   @map("default_usable_rate") @db.Decimal(5, 4)
  /// 默认损耗率（0–1）；= 1 - defaultUsableRate
  defaultLossRate        Decimal?   @map("default_loss_rate") @db.Decimal(5, 4)
  lossMode               LossMode?  @default(STANDARD) @map("loss_mode")
  optimisticUsableRate   Decimal?   @map("optimistic_usable_rate") @db.Decimal(5, 4)
  standardUsableRate     Decimal?   @map("standard_usable_rate") @db.Decimal(5, 4)
  conservativeUsableRate Decimal?   @map("conservative_usable_rate") @db.Decimal(5, 4)
  lossRateNote           String?    @map("loss_rate_note") @db.Text
  lossRateUpdatedAt      DateTime?  @map("loss_rate_updated_at")
  aliasMap               Json       @default("{}") @map("alias_map")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  materials          Material[]
  recipeLines        RecipeLine[]
  stockLossRecords   StockLossRecord[]
  purchaseOrderLines PurchaseOrderLine[]

  @@index([chineseName])
  @@index([floralRole])
  @@index([pinyinIndex])
  @@map("flower_wikis")
}

// =============================================================================
// Flower WMS — 花店仓库管理与微信小程序订单
// 架构：Product（前台成品）↔ ProductBOM ↔ Material（仓储原材料）+ Batch FIFO
// 商品分类与原材料分类完全解耦，各自独立表与中间表
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// 库存流水类型
enum StockLogType {
  INBOUND /// 采购入库（增加批次可用量）
  SALE_OUT /// 销售出库（FIFO 扣减）
  WASTAGE_OUT /// 损耗出库（FIFO 扣减）
  ADJUSTMENT /// 盘点调整（可正可负）
  IN_CANCEL /// 订单取消释放库存（对冲下单锁库）
}

/// 微信订单履约状态机
enum OrderStatus {
  PENDING_PAYMENT /// 待支付
  PAID /// 已支付 / 待制作
  PRODUCTION /// 制作中
  DELIVERING /// 配送中
  COMPLETED /// 已完成
  CANCELLED /// 已取消
}

/// 取消来源（归档色彩语义）
enum OrderCancelSource {
  CUSTOMER /// 顾客在待支付阶段取消
  ADMIN /// 店长关闭待支付订单
  REFUND /// 已付/制作中退款取消
}

/// 花艺核心角色
enum FloralRole {
  MAIN /// 主花
  FILLER /// 配花
  LINE /// 线条花
  FOLIAGE /// 叶材
}

/// 首页轮播跳转类型
enum BannerTargetType {
  PRODUCT /// 跳转商城商品详情
  ACTIVITY /// 跳转活动页（targetParam 为路径或页面标识）
  COUPON /// 跳转优惠券（targetParam 为券 ID 或活动码）
  NONE /// 仅展示，不跳转
}

// ---------------------------------------------------------------------------
// ProductCategory — 商城商品分类（二级树，CMS / 小程序）
// ---------------------------------------------------------------------------

model ProductCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  imageUrl    String?
  sortOrder   Int      @default(0)
  parentId    String?  @map("parent_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent    ProductCategory?  @relation("ProdCategoryToSub", fields: [parentId], references: [id], onDelete: Cascade)
  children  ProductCategory[] @relation("ProdCategoryToSub")
  products  ProductCategoryRelation[]

  @@index([parentId])
  @@index([sortOrder])
  @@map("product_categories_list")
}

// ---------------------------------------------------------------------------
// ProductCategoryRelation — 商品 ↔ 商品分类（复用原 product_categories 表）
// ---------------------------------------------------------------------------

model ProductCategoryRelation {
  id                String @id @default(uuid())
  spuId             String @map("product_id")
  productCategoryId String @map("product_category_id")

  spu             ProductSpu      @relation(fields: [spuId], references: [id], onDelete: Cascade)
  productCategory ProductCategory @relation(fields: [productCategoryId], references: [id], onDelete: Cascade)

  @@unique([spuId, productCategoryId])
  @@index([productCategoryId])
  @@map("product_categories")
}

// ---------------------------------------------------------------------------
// MaterialCategory — WMS 原材料大类（单层扁平，无 parentId）
// ---------------------------------------------------------------------------

model MaterialCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  materials MaterialCategoryRelation[]

  @@index([sortOrder])
  @@map("material_categories")
}

// ---------------------------------------------------------------------------
// MaterialCategoryRelation — 原材料 ↔ 原材料分类
// ---------------------------------------------------------------------------

model MaterialCategoryRelation {
  id                 String @id @default(uuid())
  materialId         String @map("material_id")
  materialCategoryId String @map("material_category_id")

  material         Material         @relation(fields: [materialId], references: [id], onDelete: Cascade)
  materialCategory MaterialCategory @relation(fields: [materialCategoryId], references: [id], onDelete: Cascade)

  @@unique([materialId, materialCategoryId])
  @@index([materialCategoryId])
  @@map("material_category_relations")
}

// ---------------------------------------------------------------------------
// ProductSpu / ProductSku — 一维单款式（SPU 公用信息 + SKU 款式）
// ---------------------------------------------------------------------------

model ProductSpu {
  id               String   @id @default(uuid())
  name             String
  description      String?  @db.Text
  maintenanceGuide String?  @map("maintenance_guide") @db.Text
  isActive         Boolean  @default(false) @map("is_active")
  isDeleted        Boolean  @default(false) @map("is_deleted")
  shippingFee      Float    @default(0) @map("shipping_fee")
  allowPreOrder    Boolean  @default(true) @map("allow_pre_order")
  productionTime   Int      @default(30) @map("production_time")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  skus       ProductSku[]
  categories ProductCategoryRelation[]
  bomItems   ProductBOM[]
  banners    Banner[]

  @@index([isActive])
  @@index([isDeleted])
  @@map("product_spus")
}

model ProductSku {
  id          String   @id @default(uuid())
  spuId       String   @map("spu_id")
  skuCode     String   @unique @map("sku_code")
  specName    String   @map("spec_name")
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  imageUrl    String?  @map("image_url")
  isMainImage Boolean  @default(false) @map("is_main_image")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  spu        ProductSpu  @relation(fields: [spuId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([spuId])
  @@index([spuId, isMainImage])
  @@map("product_skus")
}

// ---------------------------------------------------------------------------
// Banner — 首页轮播（与商品解耦，支持多场景跳转）
// ---------------------------------------------------------------------------

model Banner {
  id          String           @id @default(uuid())
  imageUrl    String           @map("image_url")
  sortOrder   Int              @default(100) @map("sort_order")
  targetType  BannerTargetType @default(NONE) @map("target_type")
  targetParam String?          @map("target_param")
  productId   String?          @map("product_id")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  spu ProductSpu? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([sortOrder])
  @@index([isActive])
  @@index([targetType])
  @@map("banners")
}

// ---------------------------------------------------------------------------
// FlowerWiki — 基础物料母表 / 数字化智库
// ---------------------------------------------------------------------------

model FlowerWiki {
  id           String     @id @default(uuid())
  photo        String?
  englishName  String     @unique @map("english_name")
  chineseName  String     @map("chinese_name")
  colorTags    String[]   @default([]) @map("color_tags")
  morphology   String?    @db.Text
  supplySeason String?    @map("supply_season")
  floralRole   FloralRole @map("floral_role")
  maintenance  String     @db.Text
  aliasMap     Json       @default("{}") @map("alias_map")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  materials Material[]

  @@index([chineseName])
  @@index([floralRole])
  @@map("flower_wikis")
}

// ---------------------------------------------------------------------------
// Material — 仓储原材料
// ---------------------------------------------------------------------------

model Material {
  id                   String   @id @default(uuid())
  materialCode         String   @unique
  name                 String
  unit                 String
  safetyStockThreshold Int      @default(0)
  wikiId               String?  @map("wiki_id")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  wiki                FlowerWiki?                @relation(fields: [wikiId], references: [id], onDelete: SetNull)
  batches             Batch[]
  stockLogs           StockLog[]
  bomLines            ProductBOM[]
  categoryRelations   MaterialCategoryRelation[]

  @@index([wikiId])
  @@map("materials")
}

// ---------------------------------------------------------------------------
// ProductBOM — 成品配方
// ---------------------------------------------------------------------------

model ProductBOM {
  id             String @id @default(uuid())
  spuId          String @map("productId")
  materialId     String
  quantityNeeded Int

  spu      ProductSpu @relation(fields: [spuId], references: [id], onDelete: Cascade)
  material Material   @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([spuId, materialId])
  @@index([materialId])
  @@map("product_bom")
}

// ---------------------------------------------------------------------------
// Batch — 原材料库存批次（FIFO）
// ---------------------------------------------------------------------------

model Batch {
  id              String    @id @default(cuid())
  materialId      String
  batchNo         String?   @unique
  inboundAt       DateTime  @default(now())
  originalQty     Int
  remainingQty    Int
  unitCost        Decimal   @db.Decimal(12, 4)
  expiresAt       DateTime?
  storageLocation String?
  supplier        String?
  note            String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  material  Material   @relation(fields: [materialId], references: [id], onDelete: Restrict)
  stockLogs StockLog[]

  @@index([materialId, inboundAt])
  @@index([materialId, remainingQty])
  @@index([expiresAt])
  @@map("batches")
}

// ---------------------------------------------------------------------------
// StockLog — 库存变动流水
// ---------------------------------------------------------------------------

model StockLog {
  id            String       @id @default(cuid())
  materialId    String
  batchId       String
  type          StockLogType
  delta         Int
  quantity      Int
  orderId       String?
  orderItemId   String?
  wastageReason String?
  remark        String?      @db.Text
  operator      String?
  createdAt     DateTime     @default(now())

  material  Material   @relation(fields: [materialId], references: [id], onDelete: Restrict)
  batch     Batch      @relation(fields: [batchId], references: [id], onDelete: Restrict)
  order     Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@index([materialId, createdAt])
  @@index([batchId, createdAt])
  @@index([type, createdAt])
  @@index([orderId])
  @@index([orderItemId])
  @@map("stock_logs")
}

// ---------------------------------------------------------------------------
// User — 小程序用户（OpenID 主键体系）
// ---------------------------------------------------------------------------

model User {
  id                   String   @id @default(uuid())
  openId               String   @unique @map("open_id")
  nickName             String?  @map("nick_name")
  avatarUrl            String?  @map("avatar_url")
  defaultReceiverName  String?  @map("default_receiver_name")
  defaultReceiverPhone String?  @map("default_receiver_phone")
  defaultAddress       String?  @map("default_address") @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  orders Order[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// Order / OrderItem
// ---------------------------------------------------------------------------

model Order {
  id              String      @id @default(uuid())
  orderNo         String      @unique @map("order_no")
  userId          String      @map("user_id")
  totalAmount     Float       @map("total_amount")
  deliveryFee     Float       @default(0) @map("delivery_fee")
  payAmount       Float       @map("pay_amount")
  receiverName    String      @map("receiver_name")
  receiverPhone   String      @map("receiver_phone")
  deliveryAddress String      @map("delivery_address") @db.Text
  deliveryDate    String      @map("delivery_date")
  greetingCard    String?     @map("greeting_card") @db.Text
  deliveryInfo    String?     @map("delivery_info") @db.Text
  status          OrderStatus @default(PENDING_PAYMENT)
  paidAt          DateTime?   @map("paid_at")
  refundAmount    Float?           @map("refund_amount")
  refundTime      DateTime?        @map("refund_time")
  cancelSource    OrderCancelSource? @map("cancel_source")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user      User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  items     OrderItem[]
  stockLogs StockLog[]

  @@index([status, createdAt])
  @@index([userId])
  @@index([orderNo])
  @@map("orders")
}

model OrderItem {
  id                   String   @id @default(uuid())
  orderId              String   @map("order_id")
  skuId                String   @map("sku_id")
  quantity             Int
  snapshotProductName  String   @map("snapshot_product_name")
  snapshotSpecName     String   @map("snapshot_spec_name")
  snapshotPrice        Float    @map("snapshot_price")
  snapshotImageUrl     String   @map("snapshot_image_url")
  createdAt            DateTime @default(now()) @map("created_at")

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku       ProductSku @relation(fields: [skuId], references: [id], onDelete: Restrict)
  stockLogs StockLog[]

  @@index([orderId])
  @@index([skuId])
  @@map("order_items")
}

// ---------------------------------------------------------------------------
// AppConfig
// ---------------------------------------------------------------------------

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_configs")
}

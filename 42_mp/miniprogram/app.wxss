/** app.wxss — 定制花艺工作室全局样式 **/

page {
  box-sizing: border-box;
  background-color: #fcfcfc;
  color: #222222;
  font-size: 28rpx;
  line-height: 1.6;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue',
    'Microsoft YaHei', sans-serif;
}

view,
text,
image,
scroll-view,
button,
input,
textarea,
navigator {
  box-sizing: border-box;
}

/* —— 主题变量 —— */
page {
  --primary-color: #8fa89b;
  --accent-color: #dca597;
  --text-main: #222222;
  --text-muted: #777777;
  --bg-light: #f9f9f9;
}

/* —— 全局原子类 —— */

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-muted {
  color: var(--text-muted);
}

.price-text {
  color: var(--accent-color);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.tag-primary {
  color: var(--primary-color);
  background-color: rgba(143, 168, 155, 0.12);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.card {
  background-color: var(--bg-light);
  border-radius: 16rpx;
  padding: 24rpx;
}

.divider {
  height: 1rpx;
  background-color: rgba(0, 0, 0, 0.06);
  margin: 24rpx 0;
}

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.dates-page {
  min-height: 100vh;
  background: #fcfcfc;
  padding: 24rpx;
  box-sizing: border-box;
}

.dates-tip {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  padding: 20rpx;
  background: rgba(143, 168, 155, 0.08);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.dates-tip-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
}

.state-box {
  min-height: 50vh;
  flex-direction: column;
  gap: 16rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
}

.empty-desc {
  font-size: 26rpx;
  text-align: center;
  padding: 0 32rpx;
}

.primary-btn {
  background: var(--primary-color);
  color: #fff;
  font-size: 28rpx;
  margin-top: 16rpx;
}

.dates-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.date-card {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.date-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.date-name {
  font-size: 30rpx;
  font-weight: 600;
}

.date-meta {
  font-size: 24rpx;
}

.date-countdown {
  font-size: 24rpx;
  color: var(--primary-color);
}

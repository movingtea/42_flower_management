<!-- pages/cart/cart.wxml — 购物车 -->
<view class="cart-page">
  <!-- 有商品：列表 + 吸底结算栏（不用 block，避免真机 wx:else 断层） -->
  <view wx:if="{{hasItems}}" class="cart-has-items">
    <scroll-view
      class="cart-scroll"
      scroll-y
      style="height: {{scrollHeight}}px;"
    >
      <view
        wx:for="{{cartList}}"
        wx:for-item="item"
        wx:for-index="index"
        wx:key="lineKey"
        class="cart-row {{item.isInvalid ? 'cart-row--invalid' : ''}}"
      >
        <view
          class="cart-check-wrap"
          catchtap="onToggleItemSelect"
          data-line-key="{{item.lineKey}}"
        >
          <view class="checkbox {{item.selected && !item.isInvalid ? 'checkbox--checked' : ''}} {{item.isInvalid ? 'checkbox--disabled' : ''}}">
            <text wx:if="{{item.selected}}" class="checkbox-tick">✓</text>
          </view>
        </view>

        <image
          class="cart-row-image"
          src="{{baseUrl}}{{item.imageUrl}}"
          mode="aspectFill"
          lazy-load
        />

        <view class="cart-row-body">
          <view class="cart-row-title-row">
            <text class="cart-row-name text-ellipsis">{{item.name}}</text>
            <text wx:if="{{item.isInvalid}}" class="cart-invalid-tag">已下架</text>
          </view>
          <text class="cart-row-price">¥{{item.price}}</text>

          <view class="cart-row-actions">
            <view class="stepper">
              <view
                class="stepper-btn flex-center"
                catchtap="onQuantityMinus"
                data-line-key="{{item.lineKey}}"
              >−</view>
              <text class="stepper-qty">{{item.quantity}}</text>
              <view
                class="stepper-btn flex-center"
                catchtap="onQuantityPlus"
                data-line-key="{{item.lineKey}}"
              >+</view>
            </view>
            <text
              class="cart-delete"
              catchtap="onDeleteItem"
              data-line-key="{{item.lineKey}}"
            >删除</text>
          </view>
        </view>
      </view>
      <view class="cart-scroll-spacer"></view>
    </scroll-view>

    <view class="cart-footer">
      <view class="footer-select" catchtap="onToggleSelectAll">
        <view class="checkbox {{isAllSelected ? 'checkbox--checked' : ''}}">
          <text wx:if="{{isAllSelected}}" class="checkbox-tick">✓</text>
        </view>
        <text class="footer-select-label">全选</text>
      </view>

      <view class="footer-total">
        <text class="footer-total-label">合计：</text>
        <text class="footer-total-price">¥{{totalPrice}}</text>
      </view>

      <button
        class="footer-checkout-btn"
        catchtap="onCheckout"
      >结算({{totalCount}})</button>
    </view>
  </view>

  <!-- 空状态：独立 wx:if，不依赖 block 的 wx:else -->
  <view wx:if="{{!hasItems}}" class="cart-empty flex-center">
    <text class="cart-empty-icon">🛒</text>
    <text class="cart-empty-title">购物车空空如也</text>
    <text class="cart-empty-desc text-muted">去首页挑选一束心仪的花艺吧</text>
    <button class="cart-empty-btn" bindtap="onGoShopping">去逛逛</button>
  </view>
</view>

.cart-page {
  width: 100%;
  min-height: 100vh;
  background-color: #fcfcfc;
  box-sizing: border-box;
  position: relative;
}

/* 有商品时的整体容器：为 scroll-view 留出固定可视高度 */
.cart-has-items {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
}

.cart-scroll {
  width: 100%;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.cart-scroll-spacer {
  height: 180rpx;
}

.cart-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.05);
}

.cart-row--invalid {
  opacity: 0.55;
  background-color: #f5f5f5;
}

.cart-row-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.cart-invalid-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #b45309;
  background-color: #fef3c7;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.checkbox--disabled {
  border-color: #e5e5e5;
  background-color: #f0f0f0;
}

.cart-check-wrap {
  flex-shrink: 0;
  padding-top: 8rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d4d4d4;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.checkbox--checked {
  background: linear-gradient(145deg, #9eb5a8, #8fa89b);
  border-color: #8fa89b;
}

.checkbox-tick {
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 600;
}

.cart-row-image {
  width: 168rpx;
  height: 168rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.cart-row-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.cart-row-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.cart-row-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #8fa89b;
}

.cart-row-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 4rpx;
}

.stepper {
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(143, 168, 155, 0.35);
  border-radius: 999rpx;
  overflow: hidden;
  background-color: #fafafa;
}

.stepper-btn {
  width: 56rpx;
  height: 48rpx;
  font-size: 32rpx;
  color: #333333;
  line-height: 48rpx;
  text-align: center;
}

.stepper-qty {
  min-width: 56rpx;
  text-align: center;
  font-size: 26rpx;
  color: #333333;
  padding: 0 8rpx;
}

.cart-delete {
  font-size: 24rpx;
  color: #777777;
  padding: 8rpx 0;
}

/* 吸底结算栏 */
.cart-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.footer-select {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.footer-select-label {
  font-size: 26rpx;
  color: #333333;
}

.footer-total {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 4rpx;
}

.footer-total-label {
  font-size: 24rpx;
  color: #777777;
}

.footer-total-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #c45c5c;
}

.footer-checkout-btn {
  flex-shrink: 0;
  margin: 0;
  padding: 0 36rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #9eb5a8, #7d9688);
  border-radius: 999rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(125, 150, 136, 0.35);
}

.footer-checkout-btn::after {
  border: none;
}

/* 空状态 */
.cart-empty {
  width: 100%;
  min-height: 80vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 80rpx 48rpx;
  box-sizing: border-box;
}

.cart-empty-icon {
  font-size: 96rpx;
  line-height: 1;
}

.cart-empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.cart-empty-desc {
  font-size: 26rpx;
  text-align: center;
  color: #777777;
}

.cart-empty-btn {
  margin-top: 24rpx;
  padding: 0 56rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #9eb5a8, #8fa89b);
  border-radius: 999rpx;
  border: none;
}

.cart-empty-btn::after {
  border: none;
}

.detail-page {
  min-height: 100vh;
  background: #fcfcfc;
  display: flex;
  flex-direction: column;
}

.detail-loading {
  min-height: 60vh;
}

.detail-scroll {
  flex: 1;
  height: calc(100vh - 120rpx);
}

.banner-wrap {
  position: relative;
  width: 100%;
  background: #f5f5f5;
}

.detail-banner {
  width: 100%;
  height: 562rpx;
}

.detail-banner-image {
  width: 100%;
  height: 562rpx;
}

.detail-banner--placeholder {
  height: 562rpx;
}

.banner-indicator {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.38);
}

.detail-head {
  padding: 28rpx 32rpx 20rpx;
  background: #fff;
}

.detail-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
  line-height: 1.4;
}

.detail-price {
  display: block;
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #c45c5c;
}

.detail-stock-tag {
  display: inline-block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #888;
  background: #f3f3f3;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.recommend-section {
  margin-top: 16rpx;
  padding: 28rpx 0 12rpx;
  background: #fff;
}

.section-title-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  padding: 0 32rpx 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.section-sub {
  font-size: 24rpx;
}

.recommend-scroll {
  width: 100%;
  white-space: nowrap;
}

.recommend-track {
  display: inline-flex;
  gap: 20rpx;
  padding: 0 32rpx 8rpx;
}

.recommend-card {
  width: 220rpx;
  flex-shrink: 0;
  display: inline-flex;
  flex-direction: column;
}

.recommend-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.recommend-name {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #333;
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recommend-price {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #c45c5c;
  font-weight: 600;
}

.rich-section {
  margin-top: 16rpx;
  padding: 28rpx 32rpx 32rpx;
  background: #fff;
}

.rich-section .section-title {
  display: block;
  margin-bottom: 20rpx;
}

.rich-body {
  font-size: 28rpx;
  color: #444;
  line-height: 1.75;
}

.detail-scroll-spacer {
  height: 160rpx;
}

.detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.footer-icon-btn {
  flex-direction: column;
  width: 96rpx;
  flex-shrink: 0;
}

.footer-icon {
  font-size: 36rpx;
  line-height: 1.1;
}

.footer-icon-label {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

.footer-actions {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.footer-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.footer-btn--cart {
  color: #8fa89b;
  border: 2rpx solid #8fa89b;
  background: #fff;
}

.footer-btn--buy {
  color: #fff;
  background: linear-gradient(135deg, #9bb5a8, #8fa89b);
}

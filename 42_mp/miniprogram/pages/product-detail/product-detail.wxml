<!-- pages/product-detail/product-detail.wxml — 商品详情 · 礼赠说服 -->
<view class="detail-page">
  <view wx:if="{{loading}}" class="detail-loading flex-center">
    <text class="text-muted">正在加载商品详情…</text>
  </view>

  <block wx:else>
    <scroll-view class="detail-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="banner-wrap">
        <swiper
          wx:if="{{bannerImages.length}}"
          class="detail-banner"
          indicator-dots="{{bannerImages.length > 1}}"
          indicator-color="rgba(255,255,255,0.45)"
          indicator-active-color="#ffffff"
          circular="{{bannerImages.length > 1}}"
          bindchange="onBannerChange"
        >
          <swiper-item wx:for="{{bannerImages}}" wx:key="*this">
            <image class="detail-banner-image" src="{{baseUrl}}{{item}}" mode="aspectFill" />
          </swiper-item>
        </swiper>
        <view wx:else class="detail-banner detail-banner--placeholder flex-center">
          <mp-icon name="flower" size="64" />
          <text class="text-muted">暂无商品图片</text>
        </view>
        <view wx:if="{{bannerImages.length > 1}}" class="banner-indicator">{{bannerCurrent + 1}} / {{bannerImages.length}}</view>
      </view>

      <view class="detail-head">
        <text class="detail-name">{{product.name}}</text>
        <text wx:if="{{product.subtitle}}" class="detail-subtitle text-muted">{{product.subtitle}}</text>
        <text class="detail-price">{{priceLabel}}</text>
        <text class="detail-stock-tag {{canPurchase ? '' : 'detail-stock-tag--sold-out'}}">{{selectedSkuStockLabel}}</text>
        <view wx:if="{{bulkPreorderHint}}" class="detail-preorder-hint">
          <text>{{bulkPreorderHint}}</text>
        </view>
        <view wx:if="{{bulkPreorderActiveHint}}" class="detail-preorder-hint detail-preorder-hint--active">
          <text>{{bulkPreorderActiveHint}}</text>
        </view>
        <view class="detail-quantity-row">
          <text class="detail-quantity-label">数量</text>
          <input
            class="detail-quantity-input"
            type="number"
            value="{{selectedQuantity}}"
            bindinput="onQuantityChange"
          />
        </view>
      </view>

      <!-- 礼赠表达 -->
      <view class="gift-section">
        <view wx:if="{{occasionSummary}}" class="gift-block">
          <view class="gift-block-head">
            <mp-icon name="scene" size="36" />
            <text class="gift-block-title">适合场景</text>
          </view>
          <text class="gift-block-text">{{occasionSummary}}</text>
        </view>

        <view wx:if="{{relationshipSummary}}" class="gift-block">
          <view class="gift-block-head">
            <mp-icon name="relationship" size="36" />
            <text class="gift-block-title">适合对象</text>
          </view>
          <text class="gift-block-text">{{relationshipSummary}}</text>
        </view>

        <view class="gift-block">
          <view class="gift-block-head">
            <mp-icon name="flower" size="36" />
            <text class="gift-block-title">情绪表达</text>
          </view>
          <text class="gift-block-text">{{storyText}}</text>
        </view>

        <view wx:if="{{styleColorLabels.length}}" class="gift-block">
          <view class="gift-block-head">
            <mp-icon name="preference" size="36" />
            <text class="gift-block-title">花材与风格</text>
          </view>
          <product-tag-badges tags="{{styleColorLabels}}" />
        </view>

        <view class="gift-block gift-block--note">
          <text class="gift-note">{{flowerAdjustmentNote}}</text>
        </view>
      </view>

      <!-- 配送说明 -->
      <view class="info-section">
        <view class="info-block-head">
          <mp-icon name="deliveryInfo" size="36" />
          <text class="section-title section-title--inline">配送与下单说明</text>
        </view>
        <view class="info-list">
          <text wx:for="{{deliveryNotes}}" wx:key="*this" class="info-line">· {{item}}</text>
        </view>
      </view>

      <view wx:if="{{recommendList.length}}" class="recommend-section">
        <view class="section-title-row">
          <text class="section-title">推荐商品</text>
          <text class="section-sub text-muted">为你精选</text>
        </view>
        <scroll-view class="recommend-scroll" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="recommend-track">
            <view
              wx:for="{{recommendList}}"
              wx:key="id"
              class="recommend-card"
              bindtap="onRecommendTap"
              data-id="{{item.id}}"
            >
              <image class="recommend-image" src="{{baseUrl}}{{item.imageUrl}}" mode="aspectFill" lazy-load />
              <text class="recommend-name text-ellipsis">{{item.name}}</text>
              <text class="recommend-price">¥{{item.price}}{{item.priceSuffix}}</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <view wx:if="{{descriptionHtml}}" class="rich-section">
        <text class="section-title">商品描述</text>
        <rich-text class="rich-body" nodes="{{descriptionHtml}}"></rich-text>
      </view>

      <view wx:if="{{maintenanceHtml}}" class="rich-section">
        <view class="info-block-head">
          <mp-icon name="care" size="36" />
          <text class="section-title section-title--inline">花艺养护指南</text>
        </view>
        <rich-text class="rich-body" nodes="{{maintenanceHtml}}"></rich-text>
      </view>

      <view class="brand-footer">
        <text class="brand-footer-text text-muted">Universe42 · 让花说话，是我们的超能力。</text>
      </view>

      <view class="detail-scroll-spacer safe-area-bottom"></view>
    </scroll-view>

    <view class="detail-footer safe-area-bottom">
      <view class="footer-icon-btn flex-center" bindtap="onGoCart">
        <mp-icon name="cart" size="40" />
        <text class="footer-icon-label">购物车</text>
      </view>
      <view class="footer-actions">
        <view class="footer-btn footer-btn--cart flex-center {{canPurchase ? '' : 'footer-btn--disabled'}}" bindtap="onOpenSpecPicker" data-mode="cart">加入购物车</view>
        <view class="footer-btn footer-btn--buy flex-center {{canPurchase ? '' : 'footer-btn--disabled'}}" bindtap="onOpenSpecPicker" data-mode="buy">立即预订</view>
      </view>
    </view>
  </block>
</view>

<spec-picker
  visible="{{specPickerVisible}}"
  product="{{product}}"
  base-url="{{baseUrl}}"
  bind:close="onSpecPickerClose"
  bind:confirm="onSpecPickerConfirm"
/>

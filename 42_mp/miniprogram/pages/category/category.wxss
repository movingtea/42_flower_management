/** pages/category/category.wxss — 商品分类页 */

.category-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background-color: #fcfcfc;
}

.scene-banner {
  padding: 20rpx 24rpx 8rpx;
  background: #fff;
}

.scene-banner-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
}

/* —— 吸顶搜索 —— */
.search-sticky {
  position: sticky;
  top: 0;
  z-index: 20;
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 72rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  border: 1rpx solid rgba(143, 168, 155, 0.2);
}

.search-icon {
  flex-shrink: 0;
  font-size: 28rpx;
  opacity: 0.55;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  font-size: 28rpx;
  color: var(--text-main);
}

.search-placeholder {
  color: #aaaaaa;
  font-size: 28rpx;
}

.search-clear {
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--primary-color);
  padding: 8rpx 0 8rpx 12rpx;
}

/* —— 主体左右分栏 —— */
.main-body {
  flex: 1;
  min-height: 0;
  display: flex;
  overflow: hidden;
}

.nav-scroll {
  width: 200rpx;
  flex-shrink: 0;
  height: 100%;
  background-color: #f3f4f3;
}

.nav-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  padding: 28rpx 16rpx 28rpx 24rpx;
  color: var(--text-muted);
  font-size: 26rpx;
  line-height: 1.4;
}

.nav-item--level2 {
  padding-left: 48rpx;
  font-size: 24rpx;
  background-color: #eceeed;
}

.nav-item--active {
  color: var(--text-main);
  font-weight: 600;
  background-color: #ffffff;
}

.nav-item--active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 48rpx;
  border-radius: 0 6rpx 6rpx 0;
  background: linear-gradient(180deg, #9eb5a8, #8fa89b);
}

.nav-item-text {
  flex: 1;
  min-width: 0;
}

.nav-expand-icon {
  flex-shrink: 0;
  font-size: 32rpx;
  color: #bbbbbb;
  transform: rotate(0deg);
  transition: transform 0.2s ease;
}

.nav-expand-icon--open {
  transform: rotate(90deg);
}

.nav-empty {
  padding: 48rpx 16rpx;
  text-align: center;
}

.product-scroll {
  flex: 1;
  min-width: 0;
  height: 100%;
  background-color: #ffffff;
}

.product-scroll-inner {
  padding: 16rpx 20rpx 32rpx;
  /* TabBar 安全区 + 额外留白，避免最后一行被遮挡 */
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom) + 100rpx);
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom) + 100rpx);
}

.state-hint {
  min-height: 480rpx;
}

.product-empty-text {
  font-size: 28rpx;
  color: #aaaaaa;
  letter-spacing: 2rpx;
}

/* —— 商品双列 —— */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.product-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.06);
}

.product-image-wrap {
  position: relative;
  width: 100%;
  height: 280rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
}

.out-of-stock-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 2;
}

.out-of-stock-text {
  color: #ffffff;
  font-size: 22rpx;
}

.product-info {
  padding: 16rpx 14rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.product-name {
  font-size: 26rpx;
  color: var(--text-main);
  font-weight: 500;
}

.product-subtitle {
  font-size: 22rpx;
}

.product-info-bottom {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.price-text {
  font-size: 28rpx;
  color: var(--accent-color);
  font-weight: 600;
  flex: 1;
  min-width: 0;
}

.cart-add-btn {
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #9eb5a8, #8fa89b);
  box-shadow: 0 6rpx 16rpx rgba(143, 168, 155, 0.35);
}

.cart-add-icon {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 300;
  line-height: 1;
}

<!-- pages/category/category.wxml — 商品分类 -->
<view class="category-page">
  <!-- 吸顶搜索 -->
  <view class="search-sticky">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        type="text"
        value="{{keyword}}"
        placeholder="搜索花艺商品名称"
        placeholder-class="search-placeholder"
        confirm-type="search"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <text
        wx:if="{{keyword}}"
        class="search-clear"
        catchtap="onClearSearch"
      >清除</text>
    </view>
  </view>

  <!-- 左导航 + 右商品 -->
  <view class="main-body">
    <scroll-view
      class="nav-scroll"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
    >
      <view
        wx:for="{{navList}}"
        wx:key="id"
        class="nav-item {{item.level === 2 ? 'nav-item--level2' : 'nav-item--level1'}} {{activeCategoryId === item.id ? 'nav-item--active' : ''}}"
        bindtap="onCategoryTap"
        data-id="{{item.id}}"
        data-has-children="{{item.hasChildren}}"
      >
        <text class="nav-item-text">{{item.name}}</text>
        <text
          wx:if="{{item.level === 1 && item.hasChildren}}"
          class="nav-expand-icon {{item.isExpanded ? 'nav-expand-icon--open' : ''}}"
        >›</text>
      </view>

      <view wx:if="{{!navList.length && !loadingCategories}}" class="nav-empty">
        <text class="text-muted">暂无分类</text>
      </view>
    </scroll-view>

    <scroll-view
      class="product-scroll"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
    >
      <view class="product-scroll-inner safe-area-bottom">
        <view wx:if="{{loadingProducts}}" class="state-hint flex-center">
          <text class="text-muted">正在加载商品…</text>
        </view>

        <view wx:elif="{{products.length}}" class="product-grid">
          <view
            wx:for="{{products}}"
            wx:key="id"
            class="product-card"
            bindtap="onProductTap"
            data-id="{{item.id}}"
            data-out-of-stock="{{item.isOutOfStock}}"
          >
            <view class="product-image-wrap">
              <image
                class="product-image"
                src="{{item.imageUrl}}"
                mode="aspectFill"
                lazy-load="{{true}}"
              />
              <view
                wx:if="{{item.isOutOfStock}}"
                class="out-of-stock-mask flex-center"
              >
                <text class="out-of-stock-text">今日售罄</text>
              </view>
            </view>
            <view class="product-info">
              <text class="product-name text-ellipsis">{{item.name}}</text>
              <text
                wx:if="{{item.subtitle}}"
                class="product-subtitle text-ellipsis text-muted"
              >{{item.subtitle}}</text>
              <view class="product-info-bottom">
                <text class="price-text">¥{{item.price}}</text>
                <view
                  class="cart-add-btn flex-center"
                  catchtap="onAddCart"
                  data-product="{{item}}"
                >
                  <text class="cart-add-icon">+</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <view wx:else class="state-hint flex-center product-empty">
          <text class="product-empty-text">该分类下暂无商品</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

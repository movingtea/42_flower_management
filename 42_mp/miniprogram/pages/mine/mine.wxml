<!-- pages/mine/mine.wxml — 我的 -->
<view class="mine-page">
  <view class="mine-header" bindtap="onGoProfile">
    <image
      wx:if="{{avatarDisplay}}"
      class="mine-avatar"
      src="{{avatarDisplay}}"
      mode="aspectFill"
    />
    <view wx:else class="mine-avatar mine-avatar--placeholder flex-center">
      <text>头像</text>
    </view>
    <view class="mine-header-text">
      <text class="mine-name">{{nickName}}</text>
      <text class="mine-sub text-muted">编辑头像与昵称</text>
    </view>
    <text class="mine-arrow">›</text>
  </view>

  <view class="mine-menu">
    <view class="mine-menu-item" bindtap="onGoOrders">
      <text>我的订单</text>
      <text class="mine-arrow">›</text>
    </view>
    <view class="mine-menu-item" bindtap="onGoProfile">
      <text>个人资料</text>
      <text class="mine-arrow">›</text>
    </view>
  </view>
</view>

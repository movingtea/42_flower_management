.mine-page {
  min-height: 100vh;
  background: #fcfcfc;
}

.mine-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 32rpx;
  background: #fff;
  margin-bottom: 16rpx;
}

.mine-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.mine-avatar--placeholder {
  background: #f0f0f0;
  font-size: 24rpx;
  color: #999;
}

.mine-header-text {
  flex: 1;
  min-width: 0;
}

.mine-name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
}

.mine-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
}

.mine-arrow {
  font-size: 40rpx;
  color: #ccc;
}

.mine-menu {
  background: #fff;
}

.mine-menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  font-size: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

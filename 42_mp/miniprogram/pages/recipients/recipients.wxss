.recipients-page {
  min-height: 100vh;
  background: #fcfcfc;
  padding: 24rpx;
  box-sizing: border-box;
}

.state-box {
  min-height: 60vh;
  flex-direction: column;
  gap: 16rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
}

.empty-desc {
  font-size: 26rpx;
  text-align: center;
  padding: 0 48rpx;
}

.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: 600;
}

.link-btn {
  margin: 0;
  color: var(--primary-color);
  background: rgba(143, 168, 155, 0.12);
  font-size: 24rpx;
}

.link-btn::after {
  border: none;
}

.recipient-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.recipient-main {
  display: flex;
  gap: 16rpx;
}

.recipient-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.recipient-name {
  font-size: 30rpx;
  font-weight: 600;
}

.recipient-meta {
  font-size: 24rpx;
}

.recipient-actions {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.action-link {
  font-size: 26rpx;
  color: var(--primary-color);
}

.action-link--danger {
  color: #c27a6b;
}

.primary-btn {
  background: var(--primary-color);
  color: #fff;
  font-size: 28rpx;
  margin-top: 16rpx;
}

.ghost-btn {
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
}

.form-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.form-sheet {
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
}

.form-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.form-field {
  margin-bottom: 20rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.field-input,
.field-textarea,
.picker-value {
  width: 100%;
  padding: 16rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.field-textarea {
  min-height: 120rpx;
}

.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.form-actions button {
  flex: 1;
}

/** pages/checkout/checkout.wxss — 极简表单布局 */

.checkout-page {
  padding: 24rpx 24rpx 48rpx;
  background-color: #fcfcfc;
  min-height: 100vh;
  box-sizing: border-box;
}

.section {
  background-color: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  color: #222222;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.fulfillment-row {
  display: flex;
  gap: 16rpx;
}

.fulfillment-btn {
  flex: 1;
  font-size: 28rpx;
  margin: 0;
  background-color: #f5f5f5;
  color: #333333;
}

.fulfillment-btn--active {
  background-color: #8fa89b;
  color: #ffffff;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.form-row:last-child {
  border-bottom: none;
}

.form-row--column {
  flex-direction: column;
  align-items: stretch;
}

.form-label {
  width: 200rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #555555;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #222222;
}

.picker-row .picker-value {
  flex: 1;
  font-size: 28rpx;
  color: #222222;
  text-align: right;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  margin-top: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.checkbox-row {
  border-bottom: none;
}

.checkbox-label-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkbox-label {
  font-size: 26rpx;
  color: #555555;
}

.order-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  font-size: 28rpx;
  gap: 16rpx;
}

.order-item-name {
  flex: 1;
  color: #222222;
}

.order-item-meta {
  color: #777777;
}

.order-item-price {
  color: #dca597;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #333333;
}

.summary-row--total {
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
  font-weight: 600;
}

.submit-btn {
  margin-top: 24rpx;
  background-color: #8fa89b;
}

/** pages/checkout/checkout.wxss — 极简表单布局 */

.checkout-page {
  padding: 24rpx 24rpx 48rpx;
  background-color: #fcfcfc;
  min-height: 100vh;
  box-sizing: border-box;
}

.section {
  background-color: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  color: #222222;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.section--address {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 24rpx;
}

.address-main {
  flex: 1;
  min-width: 0;
}

.address-filled .address-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.address-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
}

.address-phone {
  font-size: 28rpx;
  color: #555555;
}

.address-detail {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

.address-empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #8fa89b;
}

.address-empty-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

.address-arrow {
  font-size: 40rpx;
  color: #cccccc;
  flex-shrink: 0;
}

.checkout-line-spec {
  font-size: 24rpx;
  color: #888888;
}

.shipping-hint {
  display: block;
  font-size: 24rpx;
  color: #8fa89b;
  margin-bottom: 8rpx;
}

.address-import-btn {
  margin: 0;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  color: #8fa89b;
  background: rgba(143, 168, 155, 0.12);
  border-radius: 28rpx;
}

.address-import-btn::after {
  border: none;
}

.delivery-badge {
  display: inline-block;
  padding: 12rpx 28rpx;
  font-size: 28rpx;
  color: #ffffff;
  background-color: #8fa89b;
  border-radius: 999rpx;
}

.delivery-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #777777;
  line-height: 1.5;
}

.checkout-empty {
  padding: 120rpx 48rpx;
  text-align: center;
}

.checkout-empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.checkout-empty-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #777777;
}

.checkout-empty-btn {
  margin-top: 40rpx;
  background-color: #8fa89b;
  color: #ffffff;
  font-size: 28rpx;
}

.checkout-line {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.checkout-line:last-child {
  border-bottom: none;
}

.checkout-line-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.checkout-line-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.checkout-line-name {
  font-size: 28rpx;
  color: #222222;
  font-weight: 500;
}

.checkout-line-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  font-size: 24rpx;
  color: #777777;
}

.checkout-line-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.checkout-line-qty {
  font-size: 26rpx;
  color: #555555;
}

.checkout-line-subtotal {
  font-size: 28rpx;
  font-weight: 600;
  color: #dca597;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.form-row:last-child {
  border-bottom: none;
}

.form-row--column {
  flex-direction: column;
  align-items: stretch;
}

.form-label {
  width: 200rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #555555;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #222222;
}

.picker-row .picker-value {
  flex: 1;
  font-size: 28rpx;
  color: #222222;
  text-align: right;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  margin-top: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.checkbox-row {
  border-bottom: none;
}

.checkbox-label-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkbox-label {
  font-size: 26rpx;
  color: #555555;
}

.order-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  font-size: 28rpx;
  gap: 16rpx;
}

.order-item-name {
  flex: 1;
  color: #222222;
}

.order-item-meta {
  color: #777777;
}

.order-item-price {
  color: #dca597;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #333333;
}

.summary-row--total {
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
  font-weight: 600;
}

.submit-btn {
  margin-top: 24rpx;
  background-color: #8fa89b;
}

.section-title--inline {
  margin-bottom: 0;
}

.link-btn {
  margin: 0;
  padding: 0 20rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  color: #8fa89b;
  background: rgba(143, 168, 155, 0.12);
  border-radius: 28rpx;
}

.link-btn::after {
  border: none;
}

.hint-text {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #999999;
}

.hint-text--warn {
  color: #c27a6b;
}

.collapse-arrow {
  font-size: 24rpx;
  color: #8fa89b;
}

.form-textarea--small {
  min-height: 120rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.switch-row:last-child {
  border-bottom: none;
}

.switch-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
}

.switch-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
}

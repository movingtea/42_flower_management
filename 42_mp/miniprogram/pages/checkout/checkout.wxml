<!-- pages/checkout/checkout.wxml — 结算与履约（默认快递寄送） -->
<view class="checkout-page">

  <view wx:if="{{emptyCheckout}}" class="checkout-empty">
    <text class="checkout-empty-title">暂无待结算商品</text>
    <text class="checkout-empty-desc">请先在购物车中勾选要购买的商品</text>
    <button class="checkout-empty-btn" bindtap="onGoCart">返回购物车</button>
  </view>

  <view wx:if="{{!emptyCheckout}}">
    <!-- 履约方式：仅快递寄送 -->
    <view class="section">
      <view class="section-title">配送方式</view>
      <view class="delivery-badge">快递寄送</view>
      <text class="delivery-hint">订单运费按所选商品中单件运费的最高值计算</text>
    </view>

    <!-- 收货人信息 -->
    <view class="section">
      <view class="section-title-row">
        <text class="section-title">收货人信息</text>
        <button class="address-import-btn" bindtap="onChooseWechatAddress">微信地址</button>
      </view>
      <view class="form-row">
        <text class="form-label">收件人姓名</text>
        <input
          class="form-input"
          placeholder="请输入收件人姓名"
          value="{{receiverName}}"
          bindinput="onReceiverNameInput"
        />
      </view>
      <view class="form-row">
        <text class="form-label">联系电话</text>
        <input
          class="form-input"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          value="{{receiverPhone}}"
          bindinput="onReceiverPhoneInput"
        />
      </view>
      <view class="form-row">
        <text class="form-label">详细地址</text>
        <input
          class="form-input"
          placeholder="请输入详细收货地址"
          value="{{deliveryAddress}}"
          bindinput="onDeliveryAddressInput"
        />
      </view>
    </view>

    <!-- 配送与贺卡 -->
    <view class="section">
      <view class="section-title">配送与贺卡</view>

      <view class="form-row picker-row">
        <text class="form-label">期望送达日期</text>
        <picker mode="date" value="{{deliveryDate}}" start="{{minDeliveryDate}}" bindchange="onDeliveryDateChange">
          <view class="picker-value">{{deliveryDate || '请选择日期'}}</view>
        </picker>
      </view>

      <view class="form-row picker-row">
        <text class="form-label">期望送达时段</text>
        <picker
          mode="selector"
          range="{{timeBuckets}}"
          value="{{deliveryTimeBucketIndex}}"
          bindchange="onDeliveryTimeBucketChange"
        >
          <view class="picker-value">{{deliveryTimeBucket}}</view>
        </picker>
      </view>

      <view class="form-row form-row--column">
        <text class="form-label">贺卡祝福语</text>
        <textarea
          class="form-textarea"
          placeholder="可填写手写贺卡内容，留空则不需要贺卡"
          value="{{greetingCard}}"
          maxlength="200"
          bindinput="onGreetingCardInput"
        />
      </view>

      <checkbox-group class="form-row checkbox-row" bindchange="onAnonymousChange">
        <label class="checkbox-label-wrap">
          <checkbox value="anonymous" checked="{{isAnonymous}}" color="#8fa89b" />
          <text class="checkbox-label">匿名送花（不向收花人展示订购人信息）</text>
        </label>
      </checkbox-group>
    </view>

    <!-- 商品清单 -->
    <view class="section">
      <view class="section-title">商品清单</view>
      <view
        class="checkout-line"
        wx:for="{{checkoutItems}}"
        wx:for-item="item"
        wx:key="id"
      >
        <image
          wx:if="{{item.imageUrl}}"
          class="checkout-line-image"
          src="{{baseUrl}}{{item.imageUrl}}"
          mode="aspectFill"
          lazy-load
        />
        <view class="checkout-line-body">
          <text class="checkout-line-name">{{item.name}}</text>
          <view class="checkout-line-meta">
            <text>单价 ¥{{item.priceText}}</text>
            <text>运费 {{item.shippingFeeLabel}}</text>
          </view>
          <view class="checkout-line-bottom">
            <text class="checkout-line-qty">x{{item.quantity}}</text>
            <text class="checkout-line-subtotal">小计 ¥{{item.lineSubtotal}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 金额汇总 -->
    <view class="section section--summary">
      <view class="summary-row">
        <text>商品总额</text>
        <text>¥{{productTotal}}</text>
      </view>
      <view class="summary-row">
        <text>订单运费</text>
        <text>¥{{shippingFee}}</text>
      </view>
      <view class="summary-row summary-row--total">
        <text>实付款</text>
        <text class="price-text">¥{{payableTotal}}</text>
      </view>
      <button
        class="submit-btn"
        type="primary"
        loading="{{submitting}}"
        disabled="{{submitting}}"
        bindtap="onSubmitOrder"
      >提交订单并支付</button>
    </view>
  </view>

</view>

.order-list-page {
  min-height: 100vh;
  padding: 24rpx;
  background: #fcfcfc;
  box-sizing: border-box;
}

.order-list-hint,
.order-list-empty {
  padding: 120rpx 48rpx;
  text-align: center;
}

.order-list-empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.order-list-empty-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #777777;
}

.order-list-empty-btn {
  margin-top: 40rpx;
  background: #8fa89b;
  color: #ffffff;
}

.order-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.order-card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.order-no {
  font-size: 26rpx;
  color: #555555;
}

.order-status {
  font-size: 26rpx;
  font-weight: 600;
}

.order-status--PENDING_PAYMENT {
  color: #c9a227;
}

.order-status--PAID {
  color: #8fa89b;
}

.order-status--CANCELLED {
  color: #999999;
}

.order-line {
  display: flex;
  gap: 16rpx;
  padding: 12rpx 0;
}

.order-line-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.order-line-body {
  flex: 1;
  min-width: 0;
}

.order-line-name {
  display: block;
  font-size: 28rpx;
  color: #222222;
}

.order-line-spec,
.order-line-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #888888;
}

.order-card-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  font-size: 28rpx;
  font-weight: 600;
  color: #dca597;
}

.order-time {
  font-size: 24rpx;
  font-weight: 400;
  color: #999999;
}

.order-delivery {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #666666;
}

.order-greeting {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #c45c5c;
}

.order-confirm-btn {
  margin-top: 16rpx;
  background: #8fa89b;
  color: #ffffff;
  font-size: 28rpx;
}

.order-status--PRODUCTION,
.order-status--DELIVERING,
.order-status--COMPLETED {
  color: #8fa89b;
}

<!-- pages/index/index.wxml — 植物工作室首页 -->
<scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}">

  <!-- 公告栏 -->
  <view wx:if="{{notice.enabled && notice.text}}" class="notice-bar">
    <swiper
      class="notice-swiper"
      vertical
      autoplay
      circular
      interval="3500"
      duration="500"
    >
      <swiper-item>
        <view class="notice-inner flex-center">
          <text class="notice-tag">公告</text>
          <text class="notice-text text-ellipsis">{{notice.text}}</text>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 轮播图 -->
  <swiper
    wx:if="{{banners.length}}"
    class="banner-swiper"
    indicator-dots
    indicator-color="rgba(255,255,255,0.5)"
    indicator-active-color="#ffffff"
    autoplay
    circular
    interval="4500"
  >
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <image
        class="banner-image"
        src="{{baseUrl}}{{item.imageUrl}}"
        mode="aspectFill"
        bindtap="onBannerTap"
        data-target-type="{{item.targetType}}"
        data-target-param="{{item.targetParam}}"
        data-product-id="{{item.productId}}"
      />
    </swiper-item>
  </swiper>
  <view wx:else class="banner-placeholder flex-center">
    <text class="text-muted">暂无轮播内容</text>
  </view>

  <!-- 礼赠入口引导 -->
  <view class="hero-section">
    <text class="hero-title">你想把花送给谁？</text>
    <text class="hero-subtitle">让花说话，是我们的超能力。</text>
  </view>

  <!-- 快速场景入口 -->
  <view class="scene-section">
    <text class="scene-section-title">按场景选花</text>
    <view class="scene-grid">
      <view
        wx:for="{{sceneEntries}}"
        wx:key="id"
        class="scene-entry"
        bindtap="onSceneEntryTap"
        data-index="{{index}}"
      >
        <image class="scene-entry-icon" src="{{item.icon}}" mode="aspectFit" />
        <text class="scene-entry-label">{{item.title}}</text>
        <text wx:if="{{item.subtitle}}" class="scene-entry-sub text-muted">{{item.subtitle}}</text>
      </view>
    </view>
  </view>

  <!-- 首页主推 -->
  <block wx:for="{{homeMainSlots}}" wx:key="key" wx:for-item="slot">
    <view wx:if="{{slot.items.length}}" class="recommend-section">
      <view class="section-title-row">
        <text class="section-title">{{slot.name}}</text>
      </view>
      <view class="home-main-grid">
        <view
          wx:for="{{slot.items}}"
          wx:key="productId"
          wx:for-item="item"
          class="home-main-card"
          bindtap="onRecommendationTap"
          data-product-id="{{item.productId}}"
        >
          <image class="home-main-image" src="{{baseUrl}}{{item.coverImage}}" mode="aspectFill" lazy-load />
          <view class="home-main-info">
            <text class="home-main-name text-ellipsis">{{item.productName}}</text>
            <text wx:if="{{item.cardSellingPoint}}" class="home-main-point text-ellipsis text-muted">{{item.cardSellingPoint}}</text>
            <product-tag-badges tags="{{item.cardOccasionLabels}}" />
            <text class="price-text">¥{{item.price}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 新品上架 -->
  <block wx:for="{{newArrivalSlots}}" wx:key="key" wx:for-item="slot">
    <view wx:if="{{slot.items.length}}" class="recommend-section">
      <view class="section-title-row">
        <text class="section-title">{{slot.name}}</text>
      </view>
      <scroll-view class="recommend-h-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="recommend-h-track">
          <view
            wx:for="{{slot.items}}"
            wx:key="productId"
            wx:for-item="item"
            class="recommend-h-card"
            bindtap="onRecommendationTap"
            data-product-id="{{item.productId}}"
          >
            <image class="recommend-h-image" src="{{baseUrl}}{{item.coverImage}}" mode="aspectFill" lazy-load />
            <text class="recommend-h-name text-ellipsis">{{item.productName}}</text>
            <text class="price-text">¥{{item.price}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </block>

  <!-- 场景推荐 -->
  <block wx:for="{{sceneSlots}}" wx:key="key" wx:for-item="slot">
    <view wx:if="{{slot.items.length}}" class="recommend-section">
      <view class="section-title-row">
        <view>
          <text class="section-title">{{slot.name}}</text>
          <text class="section-sub text-muted">这一次，想表达什么？</text>
        </view>
      </view>
      <scroll-view class="recommend-h-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="recommend-h-track">
          <view
            wx:for="{{slot.items}}"
            wx:key="productId"
            wx:for-item="item"
            class="recommend-h-card"
            bindtap="onRecommendationTap"
            data-product-id="{{item.productId}}"
          >
            <image class="recommend-h-image" src="{{baseUrl}}{{item.coverImage}}" mode="aspectFill" lazy-load />
            <text class="recommend-h-name text-ellipsis">{{item.productName}}</text>
            <product-tag-badges tags="{{item.cardOccasionLabels}}" />
            <text class="price-text">¥{{item.price}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </block>

  <!-- 高客单形象款 -->
  <block wx:for="{{highTicketSlots}}" wx:key="key" wx:for-item="slot">
    <view wx:if="{{slot.items.length}}" class="recommend-section">
      <view class="section-title-row">
        <text class="section-title">{{slot.name}}</text>
      </view>
      <scroll-view class="recommend-h-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="recommend-h-track">
          <view
            wx:for="{{slot.items}}"
            wx:key="productId"
            wx:for-item="item"
            class="recommend-h-card"
            bindtap="onRecommendationTap"
            data-product-id="{{item.productId}}"
          >
            <image class="recommend-h-image" src="{{baseUrl}}{{item.coverImage}}" mode="aspectFill" lazy-load />
            <text class="recommend-h-name text-ellipsis">{{item.productName}}</text>
            <product-tag-badges tags="{{item.cardOccasionLabels}}" />
            <text class="price-text">¥{{item.price}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </block>

  <!-- 品牌说明 -->
  <view class="brand-section">
    <text class="brand-name">Universe42 · 万物肆贰</text>
    <text class="brand-line">让花说话，是我们的超能力。</text>
    <text class="brand-line text-muted">每一束花，都为一次具体的表达而设计。</text>
    <text class="brand-note text-muted">花材会因季节与到货状态微调，但我们会保持整体色系、风格和价值感一致。</text>
  </view>

  <!-- 动态分类 Tab -->
  <scroll-view
    class="category-scroll"
    scroll-x
    enhanced
    show-scrollbar="{{false}}"
    wx:if="{{categories.length}}"
  >
    <view class="category-tabs">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-tab {{currentTabId === item.id ? 'category-tab--active' : ''}}"
        bindtap="onCategoryTabTap"
        data-tab-id="{{item.id}}"
      >
        <text>{{item.label}}</text>
        <view wx:if="{{currentTabId === item.id}}" class="category-tab-line"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 商品双列瀑布流 -->
  <view class="product-section">
    <view wx:if="{{loading}}" class="loading-hint flex-center">
      <text class="text-muted">正在加载花艺好物…</text>
    </view>

    <view wx:elif="{{filteredProducts.length}}" class="product-grid">
      <view
        wx:for="{{filteredProducts}}"
        wx:key="id"
        class="product-card"
        bindtap="onProductTap"
        data-id="{{item.id}}"
        data-out-of-stock="{{item.isOutOfStock}}"
      >
        <view class="product-image-wrap">
          <image
            class="product-image"
            src="{{baseUrl}}{{item.imageUrl}}"
            mode="aspectFill"
            lazy-load
          />
          <view
            wx:if="{{item.isOutOfStock}}"
            class="out-of-stock-mask flex-center"
          >
            <text class="out-of-stock-text">暂时售罄</text>
          </view>
        </view>
        <view class="product-info">
          <text class="product-name text-ellipsis">{{item.name}}</text>
          <text
            wx:if="{{item.cardSellingPoint}}"
            class="product-subtitle text-ellipsis text-muted"
          >{{item.cardSellingPoint}}</text>
          <product-tag-badges tags="{{item.cardOccasionLabels}}" />
          <product-tag-badges wx:if="{{item.cardStyleColorLabels.length}}" tags="{{item.cardStyleColorLabels}}" />
          <view class="product-info-bottom">
            <view class="product-price-stock">
              <text class="price-text">¥{{item.price}}{{item.priceSuffix}}</text>
              <text class="stock-text {{item.isOutOfStock ? 'stock-text--sold-out' : ''}}">{{item.stockLabel}}</text>
            </view>
            <view
              class="cart-add-btn flex-center"
              catchtap="onAddCart"
              data-product="{{item}}"
            >
              <text class="cart-add-icon">+</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="empty-hint flex-center">
      <text class="text-muted">该分类暂无商品，敬请期待</text>
    </view>
  </view>

  <view class="page-footer safe-area-bottom"></view>
</scroll-view>

<!-- 运营弹窗 -->
<view
  wx:if="{{popupVisible && popup.enabled}}"
  class="popup-mask flex-center"
  catchtap="onClosePopup"
>
  <view class="popup-card" catchtap="onPopupCardTap">
    <image
      wx:if="{{popup.imageUrl}}"
      class="popup-image"
      src="{{baseUrl}}{{popup.imageUrl}}"
      mode="aspectFill"
    />
    <view class="popup-body">
      <text wx:if="{{popup.title}}" class="popup-title">{{popup.title}}</text>
      <text wx:if="{{popup.content}}" class="popup-content text-muted">{{popup.content}}</text>
    </view>
    <view class="popup-close flex-center" catchtap="onClosePopup">知道了</view>
  </view>
</view>

<spec-picker
  visible="{{specPickerVisible}}"
  product="{{specPickerProduct}}"
  base-url="{{baseUrl}}"
  bind:close="onSpecPickerClose"
  bind:confirm="onSpecPickerConfirm"
/>

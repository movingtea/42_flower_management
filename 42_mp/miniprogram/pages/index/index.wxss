/** pages/index/index.wxss — 植物工作室首页 */

.page-scroll {
  height: 100vh;
  background-color: #fcfcfc;
}

/* —— 公告栏 —— */
.notice-bar {
  background-color: rgba(220, 165, 151, 0.18);
  padding: 0 24rpx;
}

.notice-swiper {
  height: 64rpx;
}

.notice-inner {
  height: 64rpx;
  gap: 12rpx;
}

.notice-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--accent-color);
  background-color: rgba(220, 165, 151, 0.25);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.notice-text {
  flex: 1;
  font-size: 24rpx;
  color: #333333;
}

/* —— 轮播图 —— */
.banner-swiper {
  width: 100%;
  height: 420rpx;
}

.banner-image {
  width: 100%;
  height: 420rpx;
}

.banner-placeholder {
  height: 420rpx;
  background-color: var(--bg-light);
}

/* —— 金刚区 —— */
.kingkong-section {
  padding: 32rpx 24rpx 8rpx;
}

.kingkong-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.kingkong-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.kingkong-icon {
  font-size: 40rpx;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.kingkong-title {
  font-size: 22rpx;
  color: var(--text-main);
  letter-spacing: 1rpx;
}

/* —— 礼赠入口 —— */
.hero-section {
  padding: 28rpx 32rpx 8rpx;
}

.hero-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 1rpx;
}

.hero-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--primary-color);
}

/* —— 场景入口 —— */
.scene-section {
  padding: 16rpx 24rpx 8rpx;
}

.scene-section-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary, #333);
}

.scene-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.scene-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.scene-entry-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 8rpx;
}

.scene-entry-label {
  font-size: 26rpx;
  color: var(--text-main);
  font-weight: 500;
}

.scene-entry-sub {
  font-size: 20rpx;
  margin-top: 4rpx;
  text-align: center;
}

.section-sub {
  display: block;
  font-size: 22rpx;
  margin-top: 4rpx;
}

/* —— 品牌说明 —— */
.brand-section {
  margin: 24rpx 24rpx 0;
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(143, 168, 155, 0.08), rgba(220, 165, 151, 0.06));
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.brand-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.brand-line {
  font-size: 24rpx;
  line-height: 1.6;
}

.brand-note {
  font-size: 22rpx;
  line-height: 1.6;
  margin-top: 4rpx;
}

/* —— 场景入口（旧 chip 已移除） —— */
.scene-scroll {
  display: none;
}

/* —— 推荐位 —— */
.recommend-section {
  padding: 8rpx 24rpx 0;
}

.section-title-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
}

.home-main-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.home-main-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.home-main-image {
  width: 100%;
  height: 280rpx;
}

.home-main-info {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.home-main-name {
  font-size: 28rpx;
  font-weight: 500;
}

.home-main-point {
  font-size: 22rpx;
}

.recommend-h-scroll {
  width: 100%;
  white-space: nowrap;
}

.recommend-h-track {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.recommend-h-card {
  display: inline-flex;
  flex-direction: column;
  width: 240rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
}

.recommend-h-image {
  width: 240rpx;
  height: 240rpx;
}

.recommend-h-name {
  padding: 12rpx 12rpx 0;
  font-size: 26rpx;
}

.recommend-h-card .price-text {
  padding: 8rpx 12rpx 16rpx;
  font-size: 28rpx;
}

/* —— 分类 Tab 轴 —— */
.category-scroll {
  width: 100%;
  white-space: nowrap;
  padding: 24rpx 0 8rpx;
}

.category-tabs {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 40rpx;
}

.category-tab {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 12rpx;
  font-size: 28rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

.category-tab--active {
  color: var(--primary-color);
  font-weight: 600;
}

.category-tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background-color: var(--primary-color);
}

/* —— 商品瀑布流 —— */
.product-section {
  padding: 16rpx 24rpx 48rpx;
}

.loading-hint,
.empty-hint {
  min-height: 320rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.product-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.06);
}

.product-image-wrap {
  position: relative;
  width: 100%;
  height: 340rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
}

.out-of-stock-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  background: rgba(0, 0, 0, 0.3);
  z-index: 2;
}

.out-of-stock-text {
  color: #ffffff;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  text-align: center;
  padding: 0 16rpx;
}

.product-info {
  padding: 20rpx 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.product-name {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 500;
}

.product-subtitle {
  font-size: 22rpx;
}

.product-info-bottom {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.price-text {
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 600;
  flex: 1;
  min-width: 0;
}

.cart-add-btn {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #9eb5a8, #8fa89b);
  box-shadow: 0 6rpx 16rpx rgba(143, 168, 155, 0.35);
}

.cart-add-icon {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 300;
  line-height: 1;
}

.page-footer {
  height: 24rpx;
}

/* —— 运营弹窗 —— */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  z-index: 1000;
}

.popup-card {
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.popup-image {
  width: 100%;
  height: 320rpx;
}

.popup-body {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.popup-title {
  font-size: 32rpx;
  color: var(--text-main);
  font-weight: 600;
}

.popup-content {
  font-size: 26rpx;
  line-height: 1.6;
}

.popup-close {
  padding: 28rpx;
  font-size: 28rpx;
  color: var(--primary-color);
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

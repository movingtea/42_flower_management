# 生产环境 env — 与 docker-compose.yml 同目录放置为 .env
# 路径示例：/root/flower-platform/.env
#
#   cp .env.production.example .env
#   chmod 600 .env
#
# 变量命名与 flower-wms-system/.env.example 保持一致。
# 校验脚本：cd flower-wms-system && npm run check:production-env-example

# ==============================
# PostgreSQL（db 容器 + Prisma）
# ==============================
POSTGRES_USER=flower_admin
POSTGRES_PASSWORD=请更换为强密码
POSTGRES_DB=flower_hub_prod
DATABASE_URL=postgresql://flower_admin:请更换为强密码@db:5432/flower_hub_prod?schema=public

# ==============================
# Auth.js / NextAuth
# ==============================
NEXTAUTH_URL=https://www.universe42.studio
NEXTAUTH_SECRET=请更换为足够长的随机字符串
AUTH_SECRET=请更换为足够长的随机字符串

# ==============================
# 微信小程序（生产启用时填写）
# ==============================
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=
WECHAT_JWT_SECRET=请更换为足够长的随机字符串

# ==============================
# DeepSeek AI（WMS 物料智库补全，flower-web 需要）
# ==============================
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ==============================
# Aliyun OSS Storage（服务端 — 不得写入 NEXT_PUBLIC_*）
# ==============================
STORAGE_DRIVER=oss
ENABLE_OSS_UPLOAD=true
ENABLE_LEGACY_UPLOADS=false

ALIYUN_OSS_BUCKET=universe42
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_INTERNAL_ENDPOINT=https://oss-cn-hangzhou-internal.aliyuncs.com
# 生产 ECS 与 Bucket 同地域：使用内网 Endpoint 上传；本地开发用外网
ALIYUN_OSS_UPLOAD_ENDPOINT=https://oss-cn-hangzhou-internal.aliyuncs.com
ALIYUN_OSS_PUBLIC_BASE_URL=https://oss.universe42.studio
ALIYUN_OSS_OBJECT_PREFIX=universe42

# 服务端密钥 — 禁止 NEXT_PUBLIC_ 前缀，禁止提交真实值到 Git
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret

# ==============================
# Public image URL（浏览器 / 小程序安全访问 — 非密钥）
# ==============================
# CMS 客户端预览与 objectKey 前缀识别；与 ALIYUN_OSS_PUBLIC_BASE_URL 保持一致
NEXT_PUBLIC_OSS_PUBLIC_BASE_URL=https://oss.universe42.studio
NEXT_PUBLIC_OSS_OBJECT_PREFIX=universe42

# ==============================
# Upload Limits
# ==============================
# 业务层单张图片上限（MB）。Nginx client_max_body_size 必须大于此值（推荐 5m）
UPLOAD_MAX_SIZE_MB=3
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
UPLOAD_ALLOW_SVG=false

# ==============================
# Image storage policy
# ==============================
# DB 保存 objectKey（如 universe42/products/sku/xxx.webp），不保存完整 public URL
IMAGE_STORAGE_MODE=object_key
IMAGE_RETURN_PUBLIC_URL=true
BLOCK_LOCALHOST_IMAGE_URL=true
NORMALIZE_LOCALHOST_UPLOADS=false

# ==============================
# Docker / 发布（可选）
# ==============================
# 单 web 实例可暂保留 entrypoint migrate；多实例前见 docs/production-deployment-checklist.md D.2
# SKIP_DB_MIGRATE=true
